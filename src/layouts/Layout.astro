---
import "../styles/tokens.css";
import "../styles/globals.css";

import Header from "../components/Header.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
	title: string;
	description?: string;
	noindex?: boolean;
}

const {
	title,
	description = "Yanis Amani — CS student who builds software that doesn't break. Rust, TypeScript, systems programming.",
	noindex = false,
} = Astro.props;

const siteUrl = "https://yanis.adysen.fr";

// Per-page canonical URL — strip trailing slash to match internal link format
const canonicalPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const pageUrl = new URL(canonicalPath, siteUrl);

// JSON-LD structured data
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Yanis Amani",
	givenName: "Yanis",
	familyName: "Amani",
	jobTitle: "Computer Science Student",
	alumniOf: "HE-Arc",
	url: siteUrl,
	email: "yanis.amani@icloud.com",
	sameAs: [
		"https://linkedin.com/in/yanis-amani",
		"https://github.com/DevYatsu",
	],
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "Yanis Amani",
	url: siteUrl,
	description: "Portfolio of Yanis Amani, Computer Science student focused on building reliable software.",
	inLanguage: "en",
	author: { "@id": `${siteUrl}/#person` },
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ClientRouter />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="theme-color" content="#eceef2" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0b0e14" media="(prefers-color-scheme: dark)" />

		<link rel="canonical" href={pageUrl} />

		{noindex && <meta name="robots" content="noindex" />}

		<meta property="og:type" content="website" />
		<meta property="og:url" content={pageUrl} />
		<meta property="og:site_name" content="Yanis Amani" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/og-image.svg', siteUrl)} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="en_GB" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={pageUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL('/og-image.svg', siteUrl)} />

		<!-- Geist + JetBrains Mono (Google Fonts) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

		<!-- Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
	</head>
	<body>
		<div class="page-wrap">
			<Header />

			<main id="main-content" class="main-content">
				<slot />
			</main>

			<footer class="foot-stmt">
				<p class="foot-stmt__line">Build software that doesn't break.</p>
				<div class="foot-stmt__meta">
					<span class="foot-stmt__copy">&copy; {new Date().getFullYear()} Yanis Amani</span>
					<div class="foot-stmt__links">
						<a href="/impressum" data-lang="en" class="foot-stmt__link">Impressum</a>
						<a href="/mentions-legales" data-lang="fr" class="foot-stmt__link">Mentions Légales</a>
					</div>
				</div>
			</footer>
		</div>

		<script is:inline data-astro-rerun>
			// Theme & Language — match stored/browser preference before paint
			(function() {
				var stored = localStorage.getItem('theme');
				var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (stored === 'dark' || (!stored && prefersDark)) {
					document.documentElement.setAttribute('data-theme', 'dark');
				} else if (stored === 'light') {
					document.documentElement.setAttribute('data-theme', 'light');
				}

				var langStored = localStorage.getItem('lang');
				var browserLang = (navigator.language || navigator.userLanguage || '').substring(0, 2);
				var lang = langStored || (browserLang === 'fr' ? 'fr' : 'en');
				if (lang !== 'en') {
					document.documentElement.setAttribute('data-lang', lang);
					document.documentElement.lang = lang;
				}
			})();

			window.__setLanguage = function(lang) {
				document.documentElement.setAttribute('data-lang', lang);
				document.documentElement.lang = lang;
				localStorage.setItem('lang', lang);
				var el = document.getElementById('lang-label');
				if (el) el.textContent = lang === 'fr' ? 'EN' : 'FR';
			};
		</script>

		<script>
			// Theme toggle handler
			document.addEventListener('astro:page-load', () => {
				const btn = document.getElementById('theme-toggle');
				const html = document.documentElement;

				const updateIcon = () => {
					const isDark = html.getAttribute('data-theme') === 'dark';
					btn?.classList.toggle('dark', isDark);
				};

				btn?.addEventListener('click', () => {
					const isDark = html.getAttribute('data-theme') === 'dark';
					if (isDark) {
						html.setAttribute('data-theme', 'light');
						localStorage.setItem('theme', 'light');
					} else {
						html.setAttribute('data-theme', 'dark');
						localStorage.setItem('theme', 'dark');
					}
					updateIcon();
				});

				window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
					if (!localStorage.getItem('theme')) {
						html.setAttribute('data-theme', e.matches ? 'dark' : 'light');
						updateIcon();
					}
				});

				updateIcon();
			});
		</script>

		<script>
			// Scroll-triggered reveal animations
			document.addEventListener('astro:page-load', () => {
				const observer = new IntersectionObserver((ents) => {
					ents.forEach(e => {
						if (e.isIntersecting) {
							(e.target).classList.add('visible');
							observer.unobserve(e.target);
						}
					});
				}, { threshold: 0.1 });

				document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
			});
		</script>

		<!-- Mermaid — diagram rendering with theme support -->
		<script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
		<script is:inline>
			(function() {
				function initMermaid() {
					const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
					const paper = isDark ? '#0f121c' : '#f2f4f7';
					const paper2 = isDark ? '#1a1e2a' : '#eef0f4';
					const ink2 = isDark ? '#aeb1bf' : '#656a80';
					const rule = isDark ? '#1f2332' : '#d5d8e2';
					const accent = isDark ? '#6391e8' : '#3b7add';
					const muted = isDark ? '#8084a0' : '#878ca0';

					mermaid.initialize({
						startOnLoad: false,
						theme: 'base',
						themeVariables: {
							primaryColor: accent,
							primaryTextColor: isDark ? '#0f121c' : '#f2f4f7',
							primaryBorderColor: accent,
							lineColor: muted,
							secondaryColor: paper2,
							tertiaryColor: paper,
							fontFamily: '"Inter Variable", "Inter", ui-sans-serif, system-ui, sans-serif',
							fontSize: '14px',
							background: paper,
							mainBkg: paper2,
							nodeBorder: rule,
							clusterBkg: paper,
							clusterBorder: rule,
							titleColor: isDark ? '#eef0f4' : '#141b2c',
							edgeLabelBackground: paper2,
							nodeTextColor: ink2,
						},
					});
					document.querySelectorAll('.mermaid').forEach(el => {
						mermaid.render(el.id || 'mermaid-' + Math.random().toString(36).slice(2), el.textContent.trim())
							.then(({ svg }) => {
								el.innerHTML = svg;
							});
					});
				}

				document.addEventListener('astro:page-load', () => {
					if (typeof mermaid !== 'undefined') initMermaid();
				});

				// Re-render on theme toggle
				const themeObserver = new MutationObserver(() => {
					if (typeof mermaid !== 'undefined' && document.querySelector('.mermaid svg')) {
						initMermaid();
					}
				});
				themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
			})();
		</script>
	</body>
</html>

<style>
	.page-wrap {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.main-content {
		flex: 1;
		padding-top: 0;
	}

	/* ── Footer (Ft5 Statement) ── */
	.foot-stmt {
		padding: var(--space-2xl) var(--space-md) var(--space-xl);
		max-width: 72rem;
		margin: 0 auto;
		border-top: 1px solid var(--color-rule);
	}

	@media (min-width: 768px) {
		.foot-stmt {
			padding-left: var(--space-xl);
			padding-right: var(--space-xl);
		}
	}

	.foot-stmt__line {
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 4vw, 2.75rem);
		font-weight: 600;
		line-height: 1.05;
		letter-spacing: -0.02em;
		max-width: 28ch;
		margin: 0 0 var(--space-lg);
		color: var(--color-ink);
	}

	.foot-stmt__meta {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-rule);
		font-size: var(--text-sm);
		color: var(--color-muted);
		font-family: var(--font-body);
	}

	@media (min-width: 768px) {
		.foot-stmt__meta {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
		}
	}

	.foot-stmt__links {
		display: flex;
		gap: var(--space-md);
	}

	.foot-stmt__link {
		color: var(--color-muted);
		text-decoration: none;
		transition: color var(--dur-short) var(--ease-out);
	}

	.foot-stmt__link:hover {
		color: var(--color-accent);
	}
</style>
