---
import '../styles/globals.css';
import '@fontsource-variable/inter/wght.css';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalUrl?: string | URL;
	lang?: string;
}

const {
	title,
	description = "Yanis Amani, Computer Science student at HE-Arc Neuchâtel & software developer. I build blazing-fast web applications and systems software in Rust, TypeScript, Python & C++.",
	image = "/og-image.png",
	canonicalUrl = Astro.url.href,
	lang = "en"
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://yanis-amani.netlify.app';
const canonicalStr = typeof canonicalUrl === 'string' ? canonicalUrl : canonicalUrl.toString();
const ogImageUrl = new URL(image, siteUrl).toString();
const isFr = lang === 'fr';

// ── Context-aware language switch URL ────────────────────────────
// Keeps the user on the equivalent page in the other language
// (e.g. /impressum ↔ /mentions-legales, /fr ↔ /)
const pathname = Astro.url.pathname;
const langSwitchUrl = (() => {
  if (pathname === '/impressum' || pathname === '/impressum/')    return '/mentions-legales';
  if (pathname === '/mentions-legales' || pathname === '/mentions-legales/') return '/impressum';
  if (isFr) return '/';
  return '/fr';
})();

// ── Structured Data ──────────────────────────────────────────────
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Yanis Amani",
	"givenName": "Yanis",
	"familyName": "Amani",
	"url": siteUrl,
	"jobTitle": "Software Developer",
	"description": "BSc Computer Science student at HE-Arc Neuchâtel and software developer specialising in Rust, TypeScript, Python, React & C++.",
	"email": "yanis.amani@icloud.com",
	"image": ogImageUrl,
	"sameAs": [
		"https://github.com/DevYatsu",
		"https://linkedin.com/in/yanis-amani"
	],
	"memberOf": {
		"@type": "EducationalOrganization",
		"name": "HE-Arc — Haute École Arc Ingénierie",
		"url": "https://www.he-arc.ch",
		"address": {
			"@type": "PostalAddress",
			"streetAddress": "Espace de l'Europe 11",
			"addressLocality": "Neuchâtel",
			"postalCode": "2000",
			"addressRegion": "Neuchâtel",
			"addressCountry": "CH"
		}
	},
	"knowsAbout": [
		"Rust", "TypeScript", "Python", "JavaScript", "C", "C++",
		"React", "Next.js", "Astro", "Node.js",
		"Systems Programming", "Compiler Design", "JIT Compilation",
		"Web Performance", "Real-time Applications",
		"Supabase", "PostgreSQL", "Full Stack Development",
		"Concurrency", "Memory Management"
	],
	"knowsLanguage": [
		{ "@type": "Language", "name": "French", "alternateName": "fr" },
		{ "@type": "Language", "name": "English", "alternateName": "en" }
	]
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Yanis Amani — Portfolio",
	"url": siteUrl,
	"description": description,
	"inLanguage": lang,
	"author": { "@type": "Person", "name": "Yanis Amani", "url": siteUrl },
	"potentialAction": {
		"@type": "ContactAction",
		"target": "mailto:yanis.amani@icloud.com",
		"name": "Contact Yanis Amani"
	}
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": isFr ? "Accueil" : "Home",     "item": isFr ? siteUrl + "/fr" : siteUrl },
		{ "@type": "ListItem", "position": 2, "name": isFr ? "Projets" : "Projects", "item": (isFr ? siteUrl + "/fr" : siteUrl) + "/#projects" },
		{ "@type": "ListItem", "position": 3, "name": isFr ? "Outils" : "Skills",    "item": (isFr ? siteUrl + "/fr" : siteUrl) + "/#skills" },
		{ "@type": "ListItem", "position": 4, "name": "Contact",                      "item": (isFr ? siteUrl + "/fr" : siteUrl) + "/#contact" }
	]
};
---

<!doctype html>
<html lang={lang} dir="ltr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<!-- Primary Meta -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Yanis Amani" />
		<meta name="keywords" content="Yanis Amani, Software Developer, CS Student HE-Arc, Haute École Arc Neuchâtel, Rust Developer, TypeScript Developer, Python Developer, React Developer, Systems Programmer, C++ Developer, Full Stack Developer, Web Performance, JIT Compiler, Portfolio, DevYatsu, Switzerland, Neuchâtel" />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="theme-color" content="/#0d0d0d" />
		<meta name="color-scheme" content="dark" />
		<meta name="application-name" content="Yanis Amani — Portfolio" />
		<meta name="generator" content={Astro.generator} />

		<!-- Author & copyright -->
		<meta name="copyright" content="Yanis Amani" />
		<meta name="reply-to" content="yanis.amani@icloud.com" />
		<meta name="category" content="Portfolio, Software Development, Computer Science" />

		<!-- Geographic (helps with local/regional SEO) -->
		<meta name="geo.region" content="CH-NE" />
		<meta name="geo.placename" content="Neuchâtel, Switzerland" />
		<meta name="geo.position" content="46.9919;6.9311" />
		<meta name="ICBM" content="46.9919, 6.9311" />

		<!-- Canonical -->
		<link rel="canonical" href={canonicalStr} />

		<!-- Hreflang for SEO (French vs English) -->
		<link rel="alternate" hreflang="en" href={siteUrl} />
		<link rel="alternate" hreflang="fr" href={`${siteUrl}/fr`} />
		<link rel="alternate" hreflang="x-default" href={siteUrl} />

		<!-- Sitemap -->
		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- Resource Hints — only preconnect to actually loaded origins -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="dns-prefetch" href="//github.com" />
		<link rel="dns-prefetch" href="//linkedin.com" />
		<link rel="dns-prefetch" href="//gc.zgo.at" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Yanis Amani — Portfolio" />
		<meta property="og:url" content={canonicalStr} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:alt" content="Yanis Amani, Software Developer & CS Student at HE-Arc Neuchâtel" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content={isFr ? "fr_FR" : "en_US"} />
		<meta property="og:locale:alternate" content={isFr ? "en_US" : "fr_FR"} />
		<meta property="og:see_also" content="https://github.com/DevYatsu" />
		<meta property="og:see_also" content="https://linkedin.com/in/yanis-amani" />

		<!-- Twitter / X Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@DevYatsu" />
		<meta name="twitter:creator" content="@DevYatsu" />
		<meta name="twitter:url" content={canonicalStr} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content="Yanis Amani - Software Developer Portfolio" />
		<meta name="twitter:label1" content="Role" />
		<meta name="twitter:data1" content="Software Developer & CS Student" />
		<meta name="twitter:label2" content="Location" />
		<meta name="twitter:data2" content="Neuchâtel, Switzerland" />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/favicon.svg" />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

		<!-- Privacy-First Analytics (cookieless, GDPR compliant) -->
		<script data-goatcounter="https://yatsu.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
	</head>
	<body class={lang}>
		<!-- Custom cursor (desktop only, hidden on touch) -->
		<div id="cursor-dot" aria-hidden="true"></div>

		<!-- CRT scanline effect -->
		<div class="scanline" aria-hidden="true"></div>

		<div class="relative flex flex-col min-h-screen">
			<Header lang={lang} langSwitchUrl={langSwitchUrl} />
			<main id="main-content" class="grow" tabindex="-1">
				<slot />
			</main>

			<!-- Footer -->
			<footer class="border-t border-border mt-8">
				<div class="max-w-7xl mx-auto px-6 md:px-12 py-10">
					<div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
						<!-- Left: education info -->
						<div>
							<p class="mono-label mb-1">{isFr ? 'Étudie actuellement à' : 'Currently studying at'}</p>
							<p class="text-white/70 text-sm font-medium">HE-Arc — Neuchâtel, Switzerland</p>
							<p class="text-[hsl(0,0%,30%)] text-xs font-mono mt-0.5">{isFr ? 'BSc Informatique' : 'BSc Computer Science'}</p>
						</div>

						<!-- Center: social links -->
						<nav aria-label={isFr ? 'Liens sociaux' : 'Social links'} class="flex items-center gap-6 flex-wrap">
							<a href="https://github.com/DevYatsu" target="_blank" rel="noopener noreferrer"
								title="GitHub — DevYatsu"
								aria-label="GitHub — DevYatsu" class="nav-item hover:text-white transition-colors">
								GitHub
							</a>
							<a href="https://linkedin.com/in/yanis-amani" target="_blank" rel="noopener noreferrer"
								title="LinkedIn — Yanis Amani"
								aria-label="LinkedIn — Yanis Amani" class="nav-item hover:text-white transition-colors">
								LinkedIn
							</a>
							<a href={isFr ? '/fr/#contact' : '/#contact'}
								title="Contact Yanis Amani"
								aria-label="Contact Yanis Amani" class="nav-item hover:text-orange-400 transition-colors">
								Contact
							</a>
							<span class="w-px h-4 bg-border" aria-hidden="true"></span>
						<a href={langSwitchUrl}
							data-lang-toggle
							title={isFr ? 'View English version' : 'Voir la version française'}
							aria-label={isFr ? 'Switch to English' : 'Changer en Français'}
							class="nav-item text-white hover:text-orange-400 transition-colors flex items-center gap-1.5 font-bold">
							<svg class="w-4 h-4 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
							</svg>
							{isFr ? 'FR' : 'EN'}
						</a>
						</nav>

						<!-- Right: copyright + legal -->
						<div class="flex items-center gap-4 text-[hsl(0,0%,28%)] text-xs font-mono">
							<span>© {new Date().getFullYear()} Yanis Amani</span>
							<span class="text-border" aria-hidden="true">|</span>
							<a href={isFr ? '/mentions-legales' : '/impressum'} class="hover:text-orange-500 transition-colors">
								{isFr ? 'Mentions Légales & RGPD' : 'Impressum & Privacy'}
							</a>
						</div>
					</div>
				</div>
			</footer>
		</div>

		<!-- Scroll-to-top -->
		<button id="scroll-top" aria-label={isFr ? 'Retour en haut' : 'Back to top'} title={isFr ? 'Retour en haut' : 'Back to top'}
			class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-md border border-[hsl(0,0%,20%)] bg-[hsl(0,0%,8%)]
					text-[hsl(0,0%,50%)] hover:border-orange-500/50 hover:text-orange-400
					flex items-center justify-center opacity-0 pointer-events-none
					transition-all duration-300 font-mono text-xs">
			↑
		</button>

		<script>
			// ── Custom Cursor (desktop only) ──────────────────────────────
			const dot  = document.getElementById('cursor-dot')  as HTMLElement | null;

			if (dot && window.matchMedia('(hover: hover)').matches) {
				let mx = window.innerWidth / 2, my = window.innerHeight / 2;
				let rafId: number;
				let moved = false;

				const tick = () => {
					dot.style.transform  = `translate3d(${mx}px,${my}px,0) translate(-50%,-50%)`;
					rafId = requestAnimationFrame(tick);
				};

				document.addEventListener('mousemove', (e) => {
					mx = e.clientX;
					my = e.clientY;
					if (!moved) {
						moved = true;
						document.body.classList.add('cursor-active');
						rafId = requestAnimationFrame(tick);
					}
				}, { passive: true });

				// Hover delegation
				document.body.addEventListener('mouseover', (e) => {
					const t = (e.target as HTMLElement).closest('a, button, [data-hover]');
					if (t) dot.classList.add('hovering');
				});
				document.body.addEventListener('mouseout', (e) => {
					const t = (e.target as HTMLElement).closest('a, button, [data-hover]');
					if (t) dot.classList.remove('hovering');
				});
			}

			// ── Scroll-to-top ────────────────────────────────────────────
			const scrollBtn = document.getElementById('scroll-top') as HTMLButtonElement | null;
			if (scrollBtn) {
				let ticking = false;
				window.addEventListener('scroll', () => {
					if (!ticking) {
						requestAnimationFrame(() => {
							const show = window.scrollY > 500;
							scrollBtn.classList.toggle('opacity-0', !show);
							scrollBtn.classList.toggle('pointer-events-none', !show);
							ticking = false;
						});
						ticking = true;
					}
				}, { passive: true });
				scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
			}

			// ── Scroll-aware nav border ──────────────────────────────────
			const nav = document.querySelector('nav[aria-label="Main Navigation"]') as HTMLElement | null;
			if (nav) {
				let ntick = false;
				window.addEventListener('scroll', () => {
					if (!ntick) {
						requestAnimationFrame(() => {
							nav.style.borderBottomColor = window.scrollY > 40 ? 'hsl(0,0%,16%)' : 'transparent';
							ntick = false;
						});
						ntick = true;
					}
				}, { passive: true });
			}

			// ── Intersection Observer for scroll-reveal ──────────────────
			const observer = new IntersectionObserver(entries => {
				entries.forEach(e => {
					if (e.isIntersecting) {
						(e.target as HTMLElement).classList.add('visible');
						observer.unobserve(e.target);
					}
				});
			}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

			document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

			// ── Language toggle: preserve scroll position via hash ────────
			// On home pages (/ and /fr), find which section is most visible
			// and append its #id so the browser scrolls there on the new page.
			const sections = Array.from(document.querySelectorAll('section[id], header[id]')) as HTMLElement[];

			document.querySelectorAll<HTMLAnchorElement>('[data-lang-toggle]').forEach(link => {
				link.addEventListener('click', (e) => {
					if (sections.length === 0) return; // not a page with sections (e.g. impressum)
					e.preventDefault();
					const mid = window.innerHeight / 2;
					// Find the section whose rect is closest to the viewport center
					let best = sections[0];
					let bestDist = Infinity;
					for (const s of sections) {
						const r = s.getBoundingClientRect();
						const center = r.top + r.height / 2;
						const dist = Math.abs(center - mid);
						if (dist < bestDist) { bestDist = dist; best = s; }
					}
					const base = link.getAttribute('href') || '/';
					const hash = best.id && best.id !== 'hero' ? '#' + best.id : '';
					window.location.href = base + hash;
				});
			});
		</script>
	</body>
</html>
