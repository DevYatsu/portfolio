---
import "../styles/globals.css";
import "@fontsource-variable/hanken-grotesk";
import "@fontsource-variable/plus-jakarta-sans";
import "@fontsource-variable/jetbrains-mono";

import Header from "../components/Header.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
	title: string;
	description?: string;
	lang?: string;
}

const {
	title,
	description = "Yanis Amani, Computer Science student focused on building reliable, fast, and high-quality software solutions.",
	lang = "en",
} = Astro.props;

const isFr = lang === "fr";
const siteUrl = "https://yanis-amani.netlify.app";

// ── Context-aware language switch URL ────────────────────────────
const pathname = Astro.url.pathname;
const langSwitchUrl = (() => {
	if (isFr) return "/";
	return "/fr";
})();
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ClientRouter />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0a0a0c" media="(prefers-color-scheme: dark)" />

		<!-- OpenGraph / Social -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/favicon.png', Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL('/favicon.png', Astro.url)} />

		<style is:inline>
			/* Prevent FOUC: Hide content until CSS is loaded */
			html { 
				visibility: hidden; 
				opacity: 0;
			}
		</style>
	</head>
	<body class="bg-bg-base text-text-main selection:bg-primary/20 selection:text-primary crosshair-cursor">
		<div class="relative z-10 flex flex-col min-h-screen">
			<Header lang={lang} langSwitchUrl={langSwitchUrl} />
			
			<main id="main-content" class="grow pt-16">
				<slot />
			</main>

			<footer class="border-t border-border-subtle bg-bg-surface/50 backdrop-blur-sm">
				<div class="max-w-7xl mx-auto px-6 md:px-12 py-16">
					<div class="grid grid-cols-1 md:grid-cols-4 gap-12">
						<div class="md:col-span-2 space-y-6">
							<div class="flex items-center gap-3">
								<div class="w-6 h-6 bg-primary"></div>
								<span class="font-black uppercase tracking-widest text-xs">Yanis Amani</span>
							</div>
							<p class="text-text-muted text-sm max-w-sm font-mono text-[0.7rem] uppercase leading-relaxed">
								{isFr 
									? "Créer des logiciels fiables et rapides, des applications web aux systèmes qui les font fonctionner."
									: "Building reliable software that works, from web applications to the systems that run them."
								}
							</p>
						</div>
						
						<div class="space-y-4">
							<p class="tech-label">Navigation</p>
							<nav class="flex flex-col gap-2">
								<a href="/#projects" class="nav-link" data-astro-prefetch>PROJECTS</a>
								<a href="/#skills" class="nav-link" data-astro-prefetch>STACK</a>
								<a href="/#contact" class="nav-link" data-astro-prefetch>CONTACT</a>
							</nav>
						</div>

						<div class="space-y-4">
							<p class="tech-label">System Info</p>
							<div class="font-mono text-[0.6rem] text-text-dim space-y-1">
								<p>LOC: NEUCHÂTEL, CH</p>
								<p>STATUS: ACTIVE INTAKE 2026</p>
								<p>LATENCY: <span id="ping-val">24ms</span></p>
								<p class="mt-4 opacity-40">© {new Date().getFullYear()} Y_AMANI</p>
							</div>
						</div>
					</div>
				</div>
			</footer>
		</div>

		<script>
			// Random latency simulation for the architectural feel
			setInterval(() => {
				const el = document.getElementById('ping-val');
				if (el) el.textContent = `${Math.floor(Math.random() * 15 + 15)}ms`;
			}, 3000);

			// Intersection Observer for animations
			document.addEventListener('astro:page-load', () => {
				const observer = new IntersectionObserver((ents) => {
					ents.forEach(e => {
						if (e.isIntersecting) {
							(e.target as HTMLElement).classList.add('visible');
							observer.unobserve(e.target);
						}
					});
				}, { threshold: 0.1 });
				
				document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
			});
		</script>
	</body>
</html>
