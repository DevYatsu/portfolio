---
import '../styles/globals.css';
import '@fontsource-variable/inter/wght.css';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalUrl?: string | URL;
	lang?: string;
}

const {
	title,
	description = "Yanis Amani — Computer Science student at HE-Arc Neuchâtel & software developer. I build blazing-fast web applications and systems software in Rust, TypeScript, Python & C++.",
	image = "/og-image.png",
	canonicalUrl = Astro.url.href,
	lang = "en"
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://yanis-amani.netlify.app';
const canonicalStr = typeof canonicalUrl === 'string' ? canonicalUrl : canonicalUrl.toString();
const ogImageUrl = new URL(image, siteUrl).toString();

// ── Structured Data ──────────────────────────────────────────────
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Yanis Amani",
	"givenName": "Yanis",
	"familyName": "Amani",
	"url": siteUrl,
	"jobTitle": "Software Developer",
	"description": "BSc Computer Science student at HE-Arc Neuchâtel and software developer specialising in Rust, TypeScript, Python, React & C++.",
	"email": "yanis.amani@icloud.com",
	"image": ogImageUrl,
	"sameAs": [
		"https://github.com/DevYatsu",
		"https://linkedin.com/in/yanis-amani"
	],
	"memberOf": {
		"@type": "EducationalOrganization",
		"name": "HE-Arc — Haute École Arc Ingénierie",
		"url": "https://www.he-arc.ch",
		"address": {
			"@type": "PostalAddress",
			"streetAddress": "Espace de l'Europe 11",
			"addressLocality": "Neuchâtel",
			"postalCode": "2000",
			"addressRegion": "Neuchâtel",
			"addressCountry": "CH"
		}
	},
	"knowsAbout": [
		"Rust", "TypeScript", "Python", "JavaScript", "C", "C++",
		"React", "Next.js", "Astro", "Node.js",
		"Systems Programming", "Compiler Design", "JIT Compilation",
		"Web Performance", "Real-time Applications",
		"Supabase", "PostgreSQL", "Full Stack Development",
		"Concurrency", "Memory Management"
	],
	"knowsLanguage": [
		{ "@type": "Language", "name": "French", "alternateName": "fr" },
		{ "@type": "Language", "name": "English", "alternateName": "en" }
	]
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Yanis Amani — Portfolio",
	"url": siteUrl,
	"description": description,
	"inLanguage": lang,
	"author": { "@type": "Person", "name": "Yanis Amani", "url": siteUrl },
	"potentialAction": {
		"@type": "ContactAction",
		"target": "mailto:yanis.amani@icloud.com",
		"name": "Contact Yanis Amani"
	}
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Home",     "item": siteUrl },
		{ "@type": "ListItem", "position": 2, "name": "Projects", "item": siteUrl + "/#projects" },
		{ "@type": "ListItem", "position": 3, "name": "Skills",   "item": siteUrl + "/#skills" },
		{ "@type": "ListItem", "position": 4, "name": "Contact",  "item": siteUrl + "/#contact" }
	]
};

const sitelinksSchema = {
	"@context": "https://schema.org",
	"@type": "SiteNavigationElement",
	"name": ["Projects", "Skills", "Contact", "GitHub", "LinkedIn"],
	"url": [
		siteUrl + "/#projects",
		siteUrl + "/#skills",
		siteUrl + "/#contact",
		"https://github.com/DevYatsu",
		"https://linkedin.com/in/yanis-amani"
	]
};
---

<!doctype html>
<html lang={lang} dir="ltr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />

		<!-- Primary Meta -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Yanis Amani" />
		<meta name="keywords" content="Yanis Amani, Software Developer, CS Student HE-Arc, Haute École Arc Neuchâtel, Rust Developer, TypeScript Developer, Python Developer, React Developer, Systems Programmer, C++ Developer, Full Stack Developer, Web Performance, JIT Compiler, Portfolio, DevYatsu, Switzerland, Neuchâtel" />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="theme-color" content="#0d0d0d" />
		<meta name="color-scheme" content="dark" />
		<meta name="generator" content={Astro.generator} />

		<!-- Author & copyright -->
		<meta name="copyright" content="Yanis Amani" />
		<meta name="reply-to" content="yanis.amani@icloud.com" />
		<meta name="category" content="Portfolio, Software Development, Computer Science" />

		<!-- Geographic (helps with local/regional SEO) -->
		<meta name="geo.region" content="CH-NE" />
		<meta name="geo.placename" content="Neuchâtel, Switzerland" />
		<meta name="geo.position" content="46.9919;6.9311" />
		<meta name="ICBM" content="46.9919, 6.9311" />

		<!-- Canonical -->
		<link rel="canonical" href={canonicalStr} />

		<!-- Hreflang for SEO (French vs English) -->
		<link rel="alternate" hreflang="en" href={siteUrl} />
		<link rel="alternate" hreflang="fr" href={`${siteUrl}/fr`} />
		<link rel="alternate" hreflang="x-default" href={siteUrl} />

		<!-- Sitemap -->
		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- Resource Hints -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="dns-prefetch" href="//github.com" />
		<link rel="dns-prefetch" href="//linkedin.com" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Yanis Amani — Portfolio" />
		<meta property="og:url" content={canonicalStr} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:alt" content="Yanis Amani — Software Developer & CS Student at HE-Arc Neuchâtel" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:see_also" content="https://github.com/DevYatsu" />
		<meta property="og:see_also" content="https://linkedin.com/in/yanis-amani" />

		<!-- Twitter / X Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@DevYatsu" />
		<meta name="twitter:creator" content="@DevYatsu" />
		<meta name="twitter:url" content={canonicalStr} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content="Yanis Amani — Software Developer Portfolio" />
		<meta name="twitter:label1" content="Role" />
		<meta name="twitter:data1" content="Software Developer & CS Student" />
		<meta name="twitter:label2" content="Location" />
		<meta name="twitter:data2" content="Neuchâtel, Switzerland" />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/favicon.svg" />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(sitelinksSchema)} />
	</head>
	<body class={lang}>
		<!-- Cursor -->
		<div id="cursor-dot" aria-hidden="true"></div>
		<div id="cursor-ring" aria-hidden="true"></div>

		<!-- CRT scanline effect -->
		<div class="scanline" aria-hidden="true"></div>

		<!-- Skip to content -->
		<a href="#main-content"
			class="fixed top-4 left-4 z-[9999] -translate-y-20 focus:translate-y-0 transition-transform btn btn-orange text-sm">
			Skip to content
		</a>

		<div class="relative flex flex-col min-h-screen">
			<Header />
			<main id="main-content" class="flex-grow" tabindex="-1">
				<slot />
			</main>

			<!-- Footer -->
			<footer class="border-t border-[hsl(0,0%,14%)] mt-8">
				<div class="max-w-7xl mx-auto px-6 md:px-12 py-10">
					<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
						<div>
							<p class="mono-label mb-1">Currently studying at</p>
							<p class="text-white/70 text-sm font-medium">HE-Arc — Neuchâtel, Switzerland</p>
							<p class="text-[hsl(0,0%,30%)] text-xs font-mono mt-0.5">BSc Computer Science</p>
						</div>
						<nav aria-label="Footer socials" class="flex items-center gap-6">
							<a href="https://github.com/DevYatsu" target="_blank" rel="noopener noreferrer"
								aria-label="GitHub — DevYatsu" class="nav-item hover:text-white transition-colors">
								GitHub
							</a>
							<a href="https://linkedin.com/in/yanis-amani" target="_blank" rel="noopener noreferrer"
								aria-label="LinkedIn — Yanis Amani" class="nav-item hover:text-white transition-colors">
								LinkedIn
							</a>
							<a href="mailto:yanis.amani@icloud.com"
								aria-label="Email Yanis Amani" class="nav-item hover:text-orange-400 transition-colors">
								Email
							</a>
						</nav>
						<p class="text-[hsl(0,0%,28%)] text-xs font-mono">
							© {new Date().getFullYear()} Yanis Amani
						</p>
					</div>
				</div>
			</footer>
		</div>

		<!-- Scroll-to-top -->
		<button id="scroll-top" aria-label="Back to top" title="Back to top"
			class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-md border border-[hsl(0,0%,20%)] bg-[hsl(0,0%,8%)]
					text-[hsl(0,0%,50%)] hover:border-orange-500/50 hover:text-orange-400
					flex items-center justify-center opacity-0 pointer-events-none
					transition-all duration-300 font-mono text-xs">
			↑
		</button>

		<script>
			// Custom cursor
			const dot  = document.getElementById('cursor-dot');
			const ring = document.getElementById('cursor-ring');
			let mx = 0, my = 0;

			document.addEventListener('mousemove', e => {
				mx = e.clientX; my = e.clientY;
				if (dot)  { dot.style.left  = mx + 'px'; dot.style.top  = my + 'px'; }
				if (ring) { ring.style.left = mx + 'px'; ring.style.top = my + 'px'; }
			});

			const hoverTargets = document.querySelectorAll('a, button, [data-hover]');
			hoverTargets.forEach(el => {
				el.addEventListener('mouseenter', () => ring?.classList.add('hovering'));
				el.addEventListener('mouseleave', () => ring?.classList.remove('hovering'));
			});

			// Scroll-to-top
			const scrollBtn = document.getElementById('scroll-top');
			if (scrollBtn) {
				window.addEventListener('scroll', () => {
					const show = window.scrollY > 500;
					scrollBtn.classList.toggle('opacity-0', !show);
					scrollBtn.classList.toggle('pointer-events-none', !show);
				}, { passive: true });
				scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
			}

			// IntersectionObserver for data-animate
			const observer = new IntersectionObserver(entries => {
				entries.forEach(e => {
					if (e.isIntersecting) {
						(e.target as HTMLElement).classList.add('visible');
						observer.unobserve(e.target);
					}
				});
			}, { threshold: 0.08 });
			document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

			// Sticky header
			const nav = document.querySelector('nav[aria-label="Main Navigation"]') as HTMLElement | null;
			if (nav) {
				window.addEventListener('scroll', () => {
					nav.style.borderBottomColor = window.scrollY > 40
						? 'hsl(0,0%,16%)'
						: 'transparent';
				}, { passive: true });
			}
		</script>
	</body>
</html>
