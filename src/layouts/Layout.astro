---
import "../styles/globals.css";

import Header from "../components/Header.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Yanis Amani — CS student who builds software that doesn't break. Rust, TypeScript, systems programming.",
} = Astro.props;

const siteUrl = "https://yanis.adysen.fr";

// JSON-LD structured data
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Yanis Amani",
	givenName: "Yanis",
	familyName: "Amani",
	jobTitle: "Computer Science Student",
	alumniOf: "HE-Arc",
	url: siteUrl,
	email: "yanis.amani@icloud.com",
	sameAs: [
		"https://linkedin.com/in/yanis-amani",
		"https://github.com/DevYatsu",
	],
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "Yanis Amani",
	url: siteUrl,
	description: "Portfolio of Yanis Amani, Computer Science student focused on building reliable software.",
	inLanguage: "en",
	author: { "@id": `${siteUrl}/#person` },
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<ClientRouter />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="theme-color" content="#f0f2f5" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0f172a" media="(prefers-color-scheme: dark)" />

		<link rel="canonical" href={new URL("/", siteUrl)} />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={new URL("/", siteUrl)} />
		<meta property="og:site_name" content="Yanis Amani" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/og-image.svg', siteUrl)} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="en_GB" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={new URL("/", siteUrl)} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL('/og-image.svg', siteUrl)} />

		<!-- Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
	</head>
	<body>
		<div class="page-wrap">
			<Header />

			<main id="main-content" class="main-content">
				<slot />
			</main>

			<footer class="site-footer">
				<div class="container">
					<div class="footer-inner">
						<p>&copy; {new Date().getFullYear()} Yanis Amani</p>
						<div class="footer-links">
							<a href="/impressum" data-lang="en" class="footer-link">Impressum</a>
							<a href="/mentions-legales" data-lang="fr" class="footer-link">Mentions Légales</a>
						</div>
					</div>
				</div>
			</footer>
		</div>

		<script is:inline data-astro-rerun>
			// Theme & Language — match stored/browser preference before paint
			(function() {
				var stored = localStorage.getItem('theme');
				var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (stored === 'dark' || (!stored && prefersDark)) {
					document.documentElement.setAttribute('data-theme', 'dark');
				} else if (stored === 'light') {
					document.documentElement.setAttribute('data-theme', 'light');
				}

				var langStored = localStorage.getItem('lang');
				var browserLang = (navigator.language || navigator.userLanguage || '').substring(0, 2);
				var lang = langStored || (browserLang === 'fr' ? 'fr' : 'en');
				if (lang !== 'en') {
					document.documentElement.setAttribute('data-lang', lang);
					document.documentElement.lang = lang;
				}
			})();

			window.__setLanguage = function(lang) {
				document.documentElement.setAttribute('data-lang', lang);
				document.documentElement.lang = lang;
				localStorage.setItem('lang', lang);
				var el = document.getElementById('lang-label');
				if (el) el.textContent = lang === 'fr' ? 'EN' : 'FR';
			};
		</script>

		<script>
			// Theme toggle handler
			document.addEventListener('astro:page-load', () => {
				const btn = document.getElementById('theme-toggle');
				const html = document.documentElement;

				const updateIcon = () => {
					const isDark = html.getAttribute('data-theme') === 'dark';
					btn?.classList.toggle('dark', isDark);
				};

				btn?.addEventListener('click', () => {
					const isDark = html.getAttribute('data-theme') === 'dark';
					if (isDark) {
						html.setAttribute('data-theme', 'light');
						localStorage.setItem('theme', 'light');
					} else {
						html.setAttribute('data-theme', 'dark');
						localStorage.setItem('theme', 'dark');
					}
					updateIcon();
				});

				// Listen for system changes (when no stored preference)
				window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
					if (!localStorage.getItem('theme')) {
						html.setAttribute('data-theme', e.matches ? 'dark' : 'light');
						updateIcon();
					}
				});

				updateIcon();
			});
		</script>

		<script>
			document.addEventListener('astro:page-load', () => {
				const observer = new IntersectionObserver((ents) => {
					ents.forEach(e => {
						if (e.isIntersecting) {
							(e.target).classList.add('visible');
							observer.unobserve(e.target);
						}
					});
				}, { threshold: 0.1 });

				document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
			});
		</script>

		<script>
			// Mermaid.js — lazy-loaded only on pages with .mermaid elements
			// Re-renders on theme change to match light/dark mode.
			document.addEventListener('astro:page-load', () => {
				const els = document.querySelectorAll('.mermaid');
				if (els.length === 0) return;

				function getThemeVars(isDark) {
					return isDark
						? {
							background: 'transparent',
							fontFamily: '"Inter Variable", Inter, ui-sans-serif, system-ui, sans-serif',
							fontSize: '14px',
							mainBkg: '#1e293b',
							primaryColor: '#1e293b',
							primaryBorderColor: '#60a5fa',
							primaryTextColor: '#f1f5f9',
							lineColor: '#64748b',
							secondaryColor: '#243044',
							tertiaryColor: '#2d3a4d',
							clusterBkg: 'rgba(96, 165, 250, 0.08)',
							clusterBorder: 'rgba(255, 255, 255, 0.1)',
							edgeLabelBackground: '#1e293b',
							nodeBorder: '#60a5fa',
							nodeTextColor: '#f1f5f9',
							titleColor: '#94a3b8',
							actorBorder: '#60a5fa',
							actorBkg: '#1e293b',
							actorTextColor: '#f1f5f9',
							labelBoxBkgColor: '#1e293b',
							labelBoxBorderColor: '#60a5fa',
							labelTextColor: '#f1f5f9',
							classText: '#f1f5f9',
							fillType0: '#1e293b',
							fillType1: '#243044',
							fillType2: '#2d3a4d',
							fillType3: '#1e293b',
						}
						: {
							background: 'transparent',
							fontFamily: '"Inter Variable", Inter, ui-sans-serif, system-ui, sans-serif',
							fontSize: '14px',
							mainBkg: '#ffffff',
							primaryColor: '#ffffff',
							primaryBorderColor: '#2563eb',
							primaryTextColor: '#0f172a',
							lineColor: '#94a3b8',
							secondaryColor: '#f8f9fb',
							tertiaryColor: '#eef1f6',
							clusterBkg: 'rgba(37, 99, 235, 0.05)',
							clusterBorder: 'rgba(15, 23, 42, 0.1)',
							edgeLabelBackground: '#ffffff',
							nodeBorder: '#2563eb',
							nodeTextColor: '#0f172a',
							titleColor: '#5b6d87',
							actorBorder: '#2563eb',
							actorBkg: '#ffffff',
							actorTextColor: '#0f172a',
							labelBoxBkgColor: '#ffffff',
							labelBoxBorderColor: '#2563eb',
							labelTextColor: '#0f172a',
							classText: '#0f172a',
							fillType0: '#ffffff',
							fillType1: '#f8f9fb',
							fillType2: '#eef1f6',
							fillType3: '#ffffff',
						};
				}

				function isDarkTheme() {
					return document.documentElement.getAttribute('data-theme') === 'dark'
						|| (!document.documentElement.getAttribute('data-theme')
							&& window.matchMedia('(prefers-color-scheme: dark)').matches);
				}

				async function render() {
					const vars = getThemeVars(isDarkTheme());
					mermaid.initialize({ startOnLoad: false, theme: 'base', themeVariables: vars });

					for (const el of els) {
						// Read source from dataset (re-render) or textContent (first time)
						const src = (el.dataset.mermaidSource || el.textContent || '').trim();
						if (!src) continue;
						// Save on first render so we don't need textContent next time
						if (!el.dataset.mermaidSource) {
							el.dataset.mermaidSource = src;
						}
						try {
							const { svg } = await mermaid.render(
								'mermaid-' + Math.random().toString(36).slice(2, 8),
								src,
							);
							el.innerHTML = svg;
						} catch (e) {
							console.warn('Mermaid render failed:', e);
						}
					}
				}

				if (typeof mermaid !== 'undefined') { render(); return; }
				const s = document.createElement('script');
				s.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
				s.onload = render;
				s.onerror = () => console.warn('Failed to load Mermaid.js');
				document.head.appendChild(s);

				// Watch for theme changes and re-render all diagrams
				const themeObserver = new MutationObserver(() => {
					if (typeof mermaid === 'undefined') return;
					render();
				});
				themeObserver.observe(document.documentElement, {
					attributes: true,
					attributeFilter: ['data-theme'],
				});
			});
		</script>
	</body>
</html>

<style>
	.page-wrap {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	.main-content {
		flex: 1;
		padding-top: 4rem;
	}

	.site-footer {
		border-top: 1px solid var(--border);
	}

	.footer-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		padding: 3rem 0;
	}

	@media (min-width: 768px) {
		.footer-inner {
			flex-direction: row;
			justify-content: space-between;
		}
	}

	.footer-inner p {
		font-size: 0.75rem;
		color: var(--text-dim);
	}

	.footer-links {
		display: flex;
		gap: 1rem;
	}
</style>
