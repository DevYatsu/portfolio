---
// Architectural Header - Precision Editorial Style
const { lang = "en", langSwitchUrl = lang === "fr" ? "/" : "/fr" } =
	Astro.props;

const t = {
	en: {
		projects: "PROJECTS",
		skills: "STACK",
		about: "ABOUT",
		contact: "CONTACT",
	},
	fr: {
		projects: "PROJETS",
		skills: "OUTILS",
		about: "À PROPOS",
		contact: "CONTACT",
	},
}[lang as "en" | "fr"];
---

<nav aria-label="Main Navigation"
	id="main-nav"
	class="fixed top-0 inset-x-0 z-50 bg-bg-base/80 backdrop-blur-md border-b border-border-subtle transition-all duration-500">
	
	<div class="max-w-7xl mx-auto px-6 md:px-12 h-16 flex items-center justify-between">
		<!-- Logo / Brand -->
		<a href="/#" id="nav-logo" class="flex items-center gap-3 group">
			<div class="w-8 h-8 bg-primary flex items-center justify-center transition-transform group-hover:rotate-90 duration-500">
				<span class="text-white font-black text-xs tracking-tighter">YA</span>
			</div>
			<div class="hidden sm:flex flex-col">
				<span class="text-text-main font-black text-xs tracking-tight leading-none uppercase">Yanis Amani</span>
				<span class="text-text-dim text-[0.5rem] font-mono mt-0.5 uppercase tracking-widest">Comp Sci Student</span>
			</div>
		</a>

		<!-- Desktop Navigation -->
		<div class="hidden md:flex items-center gap-8">
			<ul class="flex items-center gap-6" role="list">
				<li><a href="/#projects" class="nav-link" data-astro-prefetch>{t.projects}</a></li>
				<li><a href="/#skills" class="nav-link" data-astro-prefetch>{t.skills}</a></li>
				<li><a href="/#about" class="nav-link" data-astro-prefetch>{t.about}</a></li>
			</ul>
			
			<div class="w-px h-4 bg-border-subtle"></div>

			<div class="flex items-center gap-6">
				<a href={langSwitchUrl}
					class="font-mono text-[0.6rem] font-black text-text-dim hover:text-primary transition-colors py-1"
					data-astro-prefetch>
					{lang === 'fr' ? 'EN' : 'FR'}
				</a>

				<a href="/#contact" class="btn-arch text-[0.65rem] py-2 px-5">
					{t.contact}
				</a>
			</div>
		</div>

		<!-- Mobile menu toggle -->
		<button id="mob-btn" type="button" class="md:hidden text-text-muted hover:text-primary transition-colors p-2"
			aria-label="Open menu" aria-expanded="false">
			<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 18h16"/>
			</svg>
		</button>
	</div>

	<!-- Mobile menu overlay -->
	<div id="mob-menu" class="md:hidden hidden border-t border-border-subtle bg-bg-base/95 backdrop-blur-xl">
		<div class="px-6 py-12 flex flex-col gap-6">
			<a href="/#projects" class="display-md font-black hover:text-primary transition-colors">{t.projects}</a>
			<a href="/#skills" class="display-md font-black hover:text-primary transition-colors">{t.skills}</a>
			<a href="/#about" class="display-md font-black hover:text-primary transition-colors">{t.about}</a>
			<a href="/#contact" class="display-md font-black hover:text-primary transition-colors">{t.contact}</a>
			
			<div class="h-px bg-border-subtle my-6"></div>
			
			<div class="flex items-center justify-between font-mono text-xs">
				<a href="https://github.com/DevYatsu" target="_blank" class="text-text-dim hover:text-primary">GITHUB ↗</a>
				<a href={langSwitchUrl} class="text-primary font-black uppercase">{lang === 'fr' ? 'English' : 'Français'}</a>
			</div>
		</div>
	</div>
</nav>

<script>
	const nav = document.getElementById('main-nav');
	const btn = document.getElementById('mob-btn');
	const menu = document.getElementById('mob-menu');
	let open = false;

	// Scroll management
	window.addEventListener('scroll', () => {
		if (nav && !open) {
			if (window.scrollY > 20) {
				nav.classList.add('h-14');
				nav.classList.remove('h-16');
			} else {
				nav.classList.add('h-16');
				nav.classList.remove('h-14');
			}
		}
	}, { passive: true });

	btn?.addEventListener('click', () => {
		open = !open;
		menu?.classList.toggle('hidden', !open);
		btn.innerHTML = open 
			? '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>'
			: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 18h16"/></svg>';
	});
</script>
