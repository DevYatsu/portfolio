---
const t = {
	en: { projects: "Projects", stack: "Stack", about: "About", contact: "Contact" },
	fr: { projects: "Projets", stack: "Outils", about: "À propos", contact: "Contact" },
};
---

<nav aria-label="Main Navigation" id="main-nav" class="navbar">
	<div class="container nav-inner">
		<a href="/" id="nav-logo" class="logo">
			Yanis <span class="logo-accent">Amani</span>
		</a>

		<div class="nav-desktop">
			<ul class="nav-links">
				<li><a href="/#projects" class="nav-link" data-i18n="projects">Projects</a></li>
				<li><a href="/#skills" class="nav-link" data-i18n="stack">Stack</a></li>
				<li><a href="/#about" class="nav-link" data-i18n="about">About</a></li>
				<li><a href="/#contact" class="nav-link" data-i18n="contact">Contact</a></li>
			</ul>

			<div class="nav-divider"></div>

			<button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
				<span class="theme-icon-light" aria-hidden="true">○</span>
				<span class="theme-icon-dark" aria-hidden="true">●</span>
			</button>

			<div class="nav-divider"></div>

			<button class="nav-lang" id="lang-toggle" onclick="window.__setLanguage?.(document.documentElement.lang === 'fr' ? 'en' : 'fr')">
				<span id="lang-label">FR</span>
			</button>
		</div>

		<button id="mob-btn" type="button" class="mob-btn" aria-label="Toggle menu" aria-expanded="false">
			<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 18h16"/>
			</svg>
		</button>
	</div>

	<div id="mob-menu" class="mob-menu hidden">
		<div class="container mob-menu-inner">
			<a href="/#projects" class="mob-link" data-i18n="projects">Projets</a>
			<a href="/#skills" class="mob-link" data-i18n="stack">Outils</a>
			<a href="/#about" class="mob-link" data-i18n="about">À propos</a>
			<a href="/#contact" class="mob-link" data-i18n="contact">Contact</a>
			<div class="mob-divider"></div>
			<button class="mob-lang" onclick="window.__setLanguage?.(document.documentElement.lang === 'fr' ? 'en' : 'fr')">
				English
			</button>
		</div>
	</div>
</nav>

<script>
	document.addEventListener('astro:page-load', () => {
		// Update language toggle label on page load
		const updateLangLabel = () => {
			const label = document.getElementById('lang-label');
			if (label) {
				const isFr = document.documentElement.lang === 'fr';
				label.textContent = isFr ? 'EN' : 'FR';
			}
			// Update mobile lang text
			const mobLabel = document.querySelector('.mob-lang');
			if (mobLabel) {
				mobLabel.textContent = document.documentElement.lang === 'fr' ? 'English' : 'Français';
			}
			// Update nav link text
			const navLinks = document.querySelectorAll('[data-i18n]');
			const t = {
				en: { projects: "Projects", stack: "Stack", about: "About", contact: "Contact" },
				fr: { projects: "Projets", stack: "Outils", about: "À propos", contact: "Contact" },
			};
			const lang = document.documentElement.lang === 'fr' ? 'fr' : 'en';
			navLinks.forEach(el => {
				const key = el.dataset.i18n;
				if (t[lang] && t[lang][key]) el.textContent = t[lang][key];
			});
		};

		// Observe lang changes on <html>
		const observer = new MutationObserver(() => updateLangLabel());
		observer.observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] });
		updateLangLabel();

		// Mobile menu
		const nav = document.getElementById('main-nav');
		const btn = document.getElementById('mob-btn');
		const menu = document.getElementById('mob-menu');
		if (!nav || !btn || !menu) return;

		menu.classList.add('hidden');
		btn.innerHTML = '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 18h16"/></svg>';
		btn.setAttribute('aria-expanded', 'false');

		let open = false;

		btn.addEventListener('click', () => {
			open = !open;
			menu.classList.toggle('hidden', !open);
			btn.setAttribute('aria-expanded', String(open));
			btn.innerHTML = open
				? '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
				: '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 18h16"/></svg>';
		});

		menu.querySelectorAll('a').forEach(link => {
			link.addEventListener('click', (e) => {
				open = false;
				menu.classList.add('hidden');
				btn.setAttribute('aria-expanded', 'false');
				btn.innerHTML = '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 18h16"/></svg>';
				// Handle hash links manually for ClientRouter compat
				const href = link.getAttribute('href');
				if (href && href.startsWith('/#')) {
					const id = href.substring(2);
					const el = document.getElementById(id);
					if (el) {
						e.preventDefault();
						history.replaceState(null, '', href);
						el.scrollIntoView({ behavior: 'smooth' });
					}
				}
			});
		});

		window.addEventListener('scroll', () => {
			if (!open) {
				nav.classList.toggle('scrolled', window.scrollY > 20);
			}
		}, { passive: true });
	});
</script>

<style>
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
		transition: all 0.3s;
	}

	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 4rem;
	}

	.logo {
		font-family: var(--font-sans);
		font-weight: 600;
		font-size: 0.875rem;
		letter-spacing: -0.01em;
		color: var(--text);
		text-decoration: none;
	}

	.logo-accent { color: var(--accent); }

	.nav-desktop {
		display: none;
		align-items: center;
		gap: 2rem;
	}

	@media (min-width: 768px) {
		.nav-desktop { display: flex; }
	}

	.nav-links {
		display: flex;
		gap: 1.5rem;
	}

	.nav-divider {
		width: 1px;
		height: 1rem;
		background: var(--border);
	}

	.nav-lang {
		font-size: 0.7rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--text-muted);
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		transition: color 0.2s;
		font-family: inherit;
	}
	.nav-lang:hover { color: var(--text); }

	.mob-btn {
		display: block;
		background: none;
		border: none;
		padding: 0.5rem;
		color: var(--text-muted);
		cursor: pointer;
		transition: color 0.2s;
		touch-action: manipulation;
	}
	.mob-btn:hover { color: var(--text); }

	@media (min-width: 768px) {
		.mob-btn { display: none; }
	}

	.hidden { display: none; }

	.mob-menu {
		position: absolute;
		top: 100%;
		left: 0;
		right: 0;
		z-index: 50;
		border-top: 1px solid var(--border);
		backdrop-filter: blur(24px);
		-webkit-backdrop-filter: blur(24px);
	}

	.mob-menu-inner {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding-top: 2.5rem;
		padding-bottom: 2.5rem;
	}

	.mob-link {
		font-family: var(--font-serif);
		font-size: 1.875rem;
		color: var(--text);
		text-decoration: none;
		transition: color 0.2s;
	}
	.mob-link:hover { color: var(--accent); }

	.mob-divider {
		height: 1px;
		background: var(--border);
		margin: 0.5rem 0;
	}

	.mob-lang {
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		font-family: inherit;
		text-align: left;
		transition: color 0.2s;
	}
</style>
