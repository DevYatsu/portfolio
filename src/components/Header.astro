---
// Minimal floating header — dark editorial style
const { lang = 'en', langSwitchUrl = lang === 'fr' ? '/' : '/fr' } = Astro.props;

const t = {
	en: {
		projects: 'projects',
		skills: 'skills',
		contact: 'contact',
		hireMe: 'hire me',
		github: 'github'
	},
	fr: {
		projects: 'projets',
		skills: 'outils',
		contact: 'contact',
		hireMe: "m'engager",
		github: 'github'
	}
}[lang as 'en' | 'fr'] || {
	projects: 'projects',
	skills: 'skills',
	contact: 'contact',
	hireMe: 'hire me',
	github: 'github'
};
---

<nav aria-label="Main Navigation"
	id="main-nav"
	class="fixed top-0 inset-x-0 z-50 glass border-b border-white/5 transition-all duration-500 will-change-transform">
	
	<!-- Top Progress bar (optional premium touch) -->
	<div id="nav-progress" class="absolute top-0 left-0 h-[2px] bg-primary/40 w-0 transition-opacity duration-300 opacity-0 px-1">
		<div class="h-full w-full bg-primary shadow-[0_0_10px_rgba(255,102,0,0.5)]"></div>
	</div>

	<div class="max-w-7xl mx-auto px-6 md:px-12 h-20 flex items-center justify-between">
		<!-- ... (rest of the header remains same structure, just updating the ID and script) -->

		<!-- Logo -->
		<a href="/#" id="nav-logo" title="Yanis Amani — Home" aria-label="Go to homepage"
			class="relative flex items-center gap-4 group">
			<div class="relative w-10 h-10 rounded-xl bg-bg-surface border border-white/10 flex items-center justify-center transition-all duration-500 overflow-hidden group-hover:border-primary/50 group-hover:scale-105">
				<div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/5 transition-colors"></div>
				<span class="text-white font-black text-sm tracking-tighter">YA</span>
			</div>
			<div class="hidden sm:flex flex-col">
				<span class="text-white font-bold text-sm tracking-tight leading-none">Yanis Amani</span>
				<span class="text-text-dim text-[0.6rem] font-mono mt-1 opacity-0 -translate-y-1 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">Software Developer</span>
			</div>
		</a>

		<!-- Desktop links -->
		<div class="hidden md:flex items-center gap-10">
			<ul class="flex items-center gap-8" role="list">
				<li><a href="/#projects" class="nav-item" title="Featured Projects">{t.projects}</a></li>
				<li><a href="/#skills" class="nav-item" title="Skills & Technologies">{t.skills}</a></li>
				<li><a href="/#about" class="nav-item" title="About Yanis">{lang === 'fr' ? 'à propos' : 'about'}</a></li>
			</ul>
			
			<div class="w-px h-6 bg-white/10"></div>

			<div class="flex items-center gap-6">
				<a href={langSwitchUrl}
					data-lang-toggle
					class="text-xs font-mono font-bold text-text-muted hover:text-primary transition-colors py-1"
					aria-label={lang === 'fr' ? 'Switch to English' : 'Changer en Français'}>
					{lang === 'fr' ? 'EN' : 'FR'}
				</a>

				<a href="/#contact"
					class="btn btn-primary text-xs px-6! py-2.5!"
					title="Hire Yanis Amani" aria-label="Send an email to Yanis Amani">
					{t.contact}
				</a>
			</div>
		</div>

		<!-- Mobile menu toggle -->
		<button id="mob-btn" type="button" class="md:hidden text-text-muted hover:text-white transition-colors p-2 rounded-lg hover:bg-white/5"
			aria-label="Open menu" aria-expanded="false" aria-controls="mob-menu">
			<svg id="mob-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
			</svg>
		</button>
	</div>

	<!-- Mobile menu -->
	<div id="mob-menu"
		class="md:hidden hidden border-t border-white/5 glass shadow-2xl">
		<div class="max-w-7xl mx-auto px-6 py-8 flex flex-col gap-2">
			<a href="/#projects" class="px-4 py-4 text-lg font-bold text-text-muted hover:text-white hover:bg-white/5 rounded-2xl transition-all">
				{t.projects}
			</a>
			<a href="/#skills" class="px-4 py-4 text-lg font-bold text-text-muted hover:text-white hover:bg-white/5 rounded-2xl transition-all">
				{t.skills}
			</a>
			<a href="/#about" class="px-4 py-4 text-lg font-bold text-text-muted hover:text-white hover:bg-white/5 rounded-2xl transition-all">
				{lang === 'fr' ? 'À propos' : 'About'}
			</a>
			<a href="/#contact" class="px-4 py-4 text-lg font-bold text-text-muted hover:text-white hover:bg-white/5 rounded-2xl transition-all">
				{t.contact}
			</a>
			<div class="h-px bg-white/5 my-4"></div>
			<div class="flex items-center justify-between px-4">
				<a href="https://github.com/DevYatsu" target="_blank" rel="noopener noreferrer"
					class="text-sm font-mono text-text-dim hover:text-white transition-colors">{t.github} ↗</a>
				<a href={langSwitchUrl} data-lang-toggle class="text-sm font-mono font-bold text-primary">{lang === 'fr' ? 'English' : 'Français'}</a>
			</div>
		</div>
	</div>
</nav>

<script>
	const nav = document.getElementById('main-nav');
	const progress = document.getElementById('nav-progress');
	const btn = document.getElementById('mob-btn');
	const menu = document.getElementById('mob-menu');
	
	let lastScroll = 0;
	let open = false;

	// Scroll management
	window.addEventListener('scroll', () => {
		const currentScroll = window.scrollY;
		const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
		
		// 1. Progress bar
		if (progress) {
			const scrollPct = (currentScroll / maxScroll) * 100;
			progress.style.width = `${scrollPct}%`;
			progress.style.opacity = currentScroll > 50 ? '1' : '0';
		}

		// 2. Hide/Show on scroll
		if (nav && !open) {
			if (currentScroll > 100 && currentScroll > lastScroll) {
				nav.style.transform = 'translateY(-100%)';
			} else {
				nav.style.transform = 'translateY(0)';
			}
		}
		
		lastScroll = currentScroll;
	}, { passive: true });

	// Mobile menu
	btn?.addEventListener('click', () => {
		open = !open;
		btn.setAttribute('aria-expanded', String(open));
		menu?.classList.toggle('hidden', !open);
		if (open && nav) nav.style.transform = 'translateY(0)';
		
		if (open) {
			const links = menu?.querySelectorAll('a');
			if (links && links.length > 0) (links[0] as HTMLElement).focus();
		}
	});

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && open) {
			open = false;
			btn?.setAttribute('aria-expanded', 'false');
			menu?.classList.add('hidden');
			btn?.focus();
		}

		if (open && e.key === 'Tab') {
			const links = Array.from(menu?.querySelectorAll('a') || []);
			if (links.length > 0) {
				const first = links[0] as HTMLElement;
				const last = links[links.length - 1] as HTMLElement;
				if (e.shiftKey && document.activeElement === first) {
					e.preventDefault();
					last.focus();
				} else if (!e.shiftKey && document.activeElement === last) {
					e.preventDefault();
					first.focus();
				}
			}
		}
	});

	menu?.querySelectorAll('a').forEach(a =>
		a.addEventListener('click', () => { 
			open = false; 
			btn?.setAttribute('aria-expanded', 'false');
			menu?.classList.add('hidden'); 
		})
	);

	// Logo diagnostics easter egg
	const logo = document.getElementById('nav-logo');
	logo?.addEventListener('click', (e) => {
		if (window.location.hash === '' || window.location.hash === '#') {
			console.log("%c[SYSTEM] INITIATING DIAGNOSTICS...", "color: #ff6600; font-weight: bold;");
			setTimeout(() => console.log("%c[LOAD] Kernel: Astro 5.0 stable", "color: #888;"), 200);
			setTimeout(() => console.log("%c[LOAD] Arch: x86_64-yatsu-runtime", "color: #888;"), 400);
			setTimeout(() => console.log("%c[OK] Portfolio Integrity: 100%", "color: #00ff41;"), 600);
		}
	});
</script>
