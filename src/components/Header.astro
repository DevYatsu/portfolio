---
const t = {
	en: { projects: "Projects", stack: "Stack", about: "About", contact: "Contact" },
	fr: { projects: "Projets", stack: "Outils", about: "À propos", contact: "Contact" },
};
---

<header class="nav">
	<div class="nav__inner">
		<a href="/" class="nav__brand">YA</a>

		<nav class="nav__center">
			<a href="/#projects" class="nav__link" data-i18n="projects">Projects</a>
			<a href="/#skills" class="nav__link" data-i18n="stack">Stack</a>
			<a href="/#about" class="nav__link" data-i18n="about">About</a>
			<a href="/#contact" class="nav__link" data-i18n="contact">Contact</a>
		</nav>

		<div class="nav__right">
			<button class="nav__theme" id="theme-toggle" aria-label="Toggle theme">
				<span class="theme-icon-light">☀</span>
				<span class="theme-icon-dark">☾</span>
			</button>
			<button class="nav__lang" id="lang-toggle" onclick="window.__setLanguage?.(document.documentElement.lang === 'fr' ? 'en' : 'fr')">
				<span id="lang-label">FR</span>
			</button>
			<button id="mob-btn" class="mob-btn" aria-label="Toggle menu" aria-expanded="false">
				<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
				</svg>
			</button>
		</div>
	</div>

	<div id="mob-menu" class="mob-menu hidden">
		<div class="container">
			<a href="/#projects" class="mob-link" data-i18n="projects">Projects</a>
			<a href="/#skills" class="mob-link" data-i18n="stack">Stack</a>
			<a href="/#about" class="mob-link" data-i18n="about">About</a>
			<a href="/#contact" class="mob-link" data-i18n="contact">Contact</a>
			<hr class="mob-rule">
			<button class="mob-lang" onclick="window.__setLanguage?.(document.documentElement.lang === 'fr' ? 'en' : 'fr')">English</button>
		</div>
	</div>
</header>

<script>
	document.addEventListener('astro:page-load', () => {
		const updateLangLabel = () => {
			const label = document.getElementById('lang-label');
			if (label) {
				const isFr = document.documentElement.lang === 'fr';
				label.textContent = isFr ? 'EN' : 'FR';
			}
			const mobLabel = document.querySelector('.mob-lang');
			if (mobLabel) {
				mobLabel.textContent = document.documentElement.lang === 'fr' ? 'English' : 'Français';
			}
			const navLinks = document.querySelectorAll('[data-i18n]');
			const t = {
				en: { projects: "Projects", stack: "Stack", about: "About", contact: "Contact" },
				fr: { projects: "Projets", stack: "Outils", about: "À propos", contact: "Contact" },
			};
			const lang = document.documentElement.lang === 'fr' ? 'fr' : 'en';
			navLinks.forEach(el => {
				const key = el.dataset.i18n;
				if (t[lang] && t[lang][key]) el.textContent = t[lang][key];
			});
		};

		const observer = new MutationObserver(() => updateLangLabel());
		observer.observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] });
		updateLangLabel();

		// Scroll handler — .is-scrolled
		const header = document.querySelector('.nav');
		const onScroll = () => {
			if (!header) return;
			header.classList.toggle('is-scrolled', window.scrollY > 24);
		};
		let ticking = false;
		window.addEventListener('scroll', () => {
			if (!ticking) {
				window.requestAnimationFrame(() => {
					onScroll();
					ticking = false;
				});
				ticking = true;
			}
		});
		onScroll();

		// Mobile menu
		const btn = document.getElementById('mob-btn');
		const menu = document.getElementById('mob-menu');
		if (!btn || !menu) return;

		menu.classList.add('hidden');
		btn.setAttribute('aria-expanded', 'false');

		let open = false;

		btn.addEventListener('click', () => {
			open = !open;
			menu.classList.toggle('hidden', !open);
			btn.setAttribute('aria-expanded', String(open));
			btn.innerHTML = open
				? '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
				: '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>';
		});

		// Hash link smooth scrolling (delegated on .nav)
		const nav = document.querySelector('.nav');
		nav?.addEventListener('click', (e) => {
			const link = e.target.closest('a');
			if (!link) return;
			const href = link.getAttribute('href');
			if (!href || !href.startsWith('/#')) return;
			const id = href.substring(2);
			let el = null;
			for (const candidate of document.querySelectorAll(`[id="${id}"]`)) {
				if (candidate.offsetParent !== null) { el = candidate; break; }
			}
			if (!el) el = document.getElementById(id);
			if (!el) return;
			e.preventDefault();
			history.replaceState(null, '', href);
			const offset = 80;
			const top = el.getBoundingClientRect().top + window.scrollY - offset;
			window.scrollTo({ top, behavior: 'smooth' });
			if (open) {
				open = false;
				menu.classList.add('hidden');
				btn.setAttribute('aria-expanded', 'false');
				btn.innerHTML = '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>';
			}
		});

		// Reload hash scroll
		if (window.location.hash) {
			const id = window.location.hash.substring(1);
			let el = null;
			for (const candidate of document.querySelectorAll(`[id="${id}"]`)) {
				if (candidate.offsetParent !== null) { el = candidate; break; }
			}
			if (!el) el = document.getElementById(id);
			if (el) {
				requestAnimationFrame(() => {
					const offset = 80;
					const top = el.getBoundingClientRect().top + window.scrollY - offset;
					window.scrollTo({ top, behavior: 'smooth' });
				});
			}
		}
	});
</script>

<style>
	/* ═══ N1b Canonical SaaS Nav ═══ */
	.nav {
		position: fixed;
		inset: 0 0 auto;
		z-index: 500;
		height: 64px;
		background: transparent;
		transition: background var(--dur-short) var(--ease-out),
		            backdrop-filter var(--dur-short) var(--ease-out),
		            border-color var(--dur-short) var(--ease-out);
	}

	.nav.is-scrolled {
		background: color-mix(in srgb, var(--color-paper) 72%, transparent);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		border-bottom: 1px solid var(--color-rule);
	}

	.nav__inner {
		max-width: 72rem;
		margin: 0 auto;
		padding-inline: var(--space-md);
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	@media (min-width: 768px) {
		.nav__inner {
			padding-inline: var(--space-xl);
		}
	}

	.nav__brand {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1rem;
		letter-spacing: -0.02em;
		color: var(--color-ink);
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 0.1em;
	}

	.nav__center {
		display: flex;
		gap: var(--space-2xs);
	}

	.nav__link {
		font-family: var(--font-body);
		font-size: var(--text-sm);
		color: var(--color-ink-2);
		text-decoration: none;
		padding: 0.35rem 0.65rem;
		border-radius: var(--radius-pill);
		transition: color var(--dur-short) var(--ease-out),
		            background var(--dur-short) var(--ease-out);
	}

	.nav__link:hover {
		color: var(--color-accent);
		background: color-mix(in srgb, var(--color-accent) 6%, transparent);
	}

	.nav__link:focus-visible {
		outline: 2px solid var(--color-focus);
		outline-offset: 2px;
	}

	.nav__right {
		display: flex;
		align-items: center;
		gap: var(--space-2xs);
	}

	.nav__theme,
	.nav__lang {
		background: none;
		border: none;
		padding: 0.35rem 0.5rem;
		border-radius: var(--radius-pill);
		color: var(--color-muted);
		cursor: pointer;
		font-size: var(--text-sm);
		font-family: var(--font-body);
		transition: color var(--dur-short) var(--ease-out);
	}

	.nav__theme:hover,
	.nav__lang:hover {
		color: var(--color-accent);
	}

	.nav__theme:focus-visible,
	.nav__lang:focus-visible,
	.mob-btn:focus-visible {
		outline: 2px solid var(--color-focus);
		outline-offset: 2px;
	}

	.nav__theme .theme-icon-dark {
		opacity: 0.35;
		transition: opacity var(--dur-short) var(--ease-out);
	}

	.nav__theme.dark .theme-icon-dark {
		opacity: 1;
		color: var(--color-accent);
	}

	.nav__theme.dark .theme-icon-light {
		opacity: 0.35;
	}

	.nav__lang {
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: var(--text-xs);
	}

	/* ── Mobile ── */
	.mob-btn {
		display: none;
		background: none;
		border: none;
		padding: 0.375rem;
		color: var(--color-ink-2);
		cursor: pointer;
		touch-action: manipulation;
	}

	@media (max-width: 767px) {
		.nav {
			height: 56px;
		}

		.nav__center {
			display: none;
		}

		.nav__right :not(.mob-btn) {
			display: none;
		}

		.mob-btn {
			display: flex;
			align-items: center;
			justify-content: center;
		}
	}

	.hidden { display: none; }

	.mob-menu {
		position: fixed;
		top: 64px;
		left: 0;
		right: 0;
		z-index: 500;
		background: color-mix(in srgb, var(--color-paper) 96%, transparent);
		backdrop-filter: blur(24px);
		-webkit-backdrop-filter: blur(24px);
		border-bottom: 1px solid var(--color-rule);
		box-shadow: 0 8px 32px rgba(0,0,0,0.08);
	}

	@media (max-width: 767px) {
		.mob-menu {
			top: 56px;
		}
	}

	.mob-link {
		display: block;
		font-family: var(--font-display);
		font-size: 1.25rem;
		padding: var(--space-sm) var(--space-md);
		color: var(--color-ink);
		text-decoration: none;
		transition: color var(--dur-short) var(--ease-out);
	}

	.mob-link:hover {
		color: var(--color-accent);
	}

	.mob-rule {
		border: none;
		height: 1px;
		background: var(--color-rule);
		margin: var(--space-xs) var(--space-md);
	}

	.mob-lang {
		font-family: var(--font-body);
		font-size: var(--text-sm);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent);
		background: none;
		border: none;
		padding: var(--space-sm) var(--space-md);
		cursor: pointer;
		text-align: left;
		transition: color var(--dur-short) var(--ease-out);
	}
</style>
