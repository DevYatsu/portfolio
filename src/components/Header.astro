---
const { lang = "en", langSwitchUrl = lang === "fr" ? "/" : "/fr" } = Astro.props;

const t = {
	en: { projects: "Projects", stack: "Stack", about: "About", contact: "Contact" },
	fr: { projects: "Projets", stack: "Outils", about: "À propos", contact: "Contact" },
}[lang];

const root = lang === "fr" ? "/fr" : "/";
---

<nav aria-label="Main Navigation" id="main-nav" class="navbar">
	<div class="container nav-inner">
		<a href={root} id="nav-logo" class="logo">
			Yanis <span class="logo-accent">Amani</span>
		</a>

		<div class="nav-desktop">
			<ul class="nav-links">
				<li><a href={`${root}#projects`} class="nav-link">{t.projects}</a></li>
				<li><a href={`${root}#skills`} class="nav-link">{t.stack}</a></li>
				<li><a href={`${root}#about`} class="nav-link">{t.about}</a></li>
				<li><a href={`${root}#contact`} class="nav-link">{t.contact}</a></li>
			</ul>

			<div class="nav-divider"></div>

			<button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
				<span class="theme-icon-light" aria-hidden="true">○</span>
				<span class="theme-icon-dark" aria-hidden="true">●</span>
			</button>

			<div class="nav-divider"></div>

			<a href={langSwitchUrl} class="nav-lang">{lang === 'fr' ? 'EN' : 'FR'}</a>
		</div>

		<button id="mob-btn" type="button" class="mob-btn" aria-label="Toggle menu" aria-expanded="false">
			<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 18h16"/>
			</svg>
		</button>
	</div>

	<div id="mob-menu" class="mob-menu hidden">
		<div class="container mob-menu-inner">
			<a href={`${root}#projects`} class="mob-link">{t.projects}</a>
			<a href={`${root}#skills`} class="mob-link">{t.stack}</a>
			<a href={`${root}#about`} class="mob-link">{t.about}</a>
			<a href={`${root}#contact`} class="mob-link">{t.contact}</a>
			<div class="mob-divider"></div>
			<a href={langSwitchUrl} class="mob-lang">{lang === 'fr' ? 'English' : 'Français'}</a>
		</div>
	</div>
</nav>

<script>
	document.addEventListener('astro:page-load', () => {
		// Save language choice on manual toggle
		document.querySelectorAll('.nav-lang, .mob-lang').forEach(el => {
			el.addEventListener('click', () => {
				localStorage.setItem('lang', 'manual');
			});
		});

		// Mobile menu
		const nav = document.getElementById('main-nav');
		const btn = document.getElementById('mob-btn');
		const menu = document.getElementById('mob-menu');
		if (!nav || !btn || !menu) return;

		// Reset to closed state
		menu.classList.add('hidden');
		btn.innerHTML = '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 18h16"/></svg>';
		btn.setAttribute('aria-expanded', 'false');

		let open = false;

		btn.addEventListener('click', () => {
			open = !open;
			menu.classList.toggle('hidden', !open);
			btn.setAttribute('aria-expanded', String(open));
			btn.innerHTML = open
				? '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
				: '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 18h16"/></svg>';
		});

		// Close menu when any mobile link is clicked
		menu.querySelectorAll('a').forEach(link => {
			link.addEventListener('click', () => {
				open = false;
				menu.classList.add('hidden');
				btn.setAttribute('aria-expanded', 'false');
				btn.innerHTML = '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 18h16"/></svg>';
			});
		});

		// Scroll handler
		window.addEventListener('scroll', () => {
			if (!open) {
				nav.classList.toggle('scrolled', window.scrollY > 20);
			}
		}, { passive: true });
	});
</script>

<style>
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
		transition: all 0.3s;
	}

	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 4rem;
	}

	.logo {
		font-family: var(--font-sans);
		font-weight: 600;
		font-size: 0.875rem;
		letter-spacing: -0.01em;
		color: var(--text);
		text-decoration: none;
	}

	.logo-accent { color: var(--accent); }

	.nav-desktop {
		display: none;
		align-items: center;
		gap: 2rem;
	}

	@media (min-width: 768px) {
		.nav-desktop { display: flex; }
	}

	.nav-links {
		display: flex;
		gap: 1.5rem;
	}

	.nav-divider {
		width: 1px;
		height: 1rem;
		background: var(--border);
	}

	.nav-lang {
		font-size: 0.7rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s;
	}
	.nav-lang:hover { color: var(--text); }

	.mob-btn {
		display: block;
		background: none;
		border: none;
		padding: 0.5rem;
		color: var(--text-muted);
		cursor: pointer;
		transition: color 0.2s;
	}
	.mob-btn:hover { color: var(--text); }

	@media (min-width: 768px) {
		.mob-btn { display: none; }
	}

	.hidden { display: none; }

	.mob-menu {
		border-top: 1px solid var(--border);
		backdrop-filter: blur(24px);
		-webkit-backdrop-filter: blur(24px);
	}

	.mob-menu-inner {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding-top: 2.5rem;
		padding-bottom: 2.5rem;
	}

	.mob-link {
		font-family: var(--font-serif);
		font-size: 1.875rem;
		color: var(--text);
		text-decoration: none;
		transition: color 0.2s;
	}
	.mob-link:hover { color: var(--accent); }

	.mob-divider {
		height: 1px;
		background: var(--border);
		margin: 0.5rem 0;
	}

	.mob-lang {
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		text-decoration: none;
	}
</style>
