---
// Minimal floating header — dark editorial style
const { lang = 'en', langSwitchUrl = lang === 'fr' ? '/' : '/fr' } = Astro.props;

const t = {
	en: {
		projects: 'projects',
		skills: 'skills',
		contact: 'contact',
		hireMe: 'hire me',
		github: 'github'
	},
	fr: {
		projects: 'projets',
		skills: 'outils',
		contact: 'contact',
		hireMe: 'disponible',
		github: 'github'
	}
}[lang as 'en' | 'fr'] || {
	projects: 'projects',
	skills: 'skills',
	contact: 'contact',
	hireMe: 'hire me',
	github: 'github'
};
---

<nav aria-label="Main Navigation"
	class="fixed top-0 inset-x-0 z-50 border-b border-transparent transition-colors duration-300">
	<div class="max-w-7xl mx-auto px-6 md:px-12 h-16 flex items-center justify-between">

		<!-- Logo -->
		<a href={lang === 'fr' ? '/fr' : '/'} title="Yanis Amani — Home" aria-label="Go to homepage"
			class="flex items-center gap-3 group">
			<span class="w-8 h-8 rounded-md bg-orange flex items-center justify-center text-ink font-mono font-black text-xs tracking-wide shadow-lg group-hover:shadow-orange-500/30 transition-shadow duration-300">
				YA
			</span>
			<span class="text-sm font-mono font-bold text-subtle group-hover:text-white transition-colors duration-200">
				yanis-amani<span class="text-orange">.</span>dev
			</span>
		</a>

		<!-- Desktop links -->
		<ul class="hidden md:flex items-center gap-8" role="list">
			<li><a href="#projects" class="nav-item" title="Featured Projects">{t.projects}</a></li>
			<li><a href="#skills" class="nav-item" title="Skills & Technologies">{t.skills}</a></li>
			<li><a href="#contact" class="nav-item" title="Contact Yanis Amani">{t.contact}</a></li>
			<li>
				<a href="https://github.com/DevYatsu" target="_blank" rel="noopener noreferrer"
					class="nav-item flex items-center gap-1.5" aria-label="GitHub profile">
					<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
					</svg>
					{t.github}
				</a>
			</li>
		</ul>

		<!-- Right: hire me -->
		<div class="flex items-center gap-4">
			<!-- Language Toggle -->
			<a href={langSwitchUrl}
				data-lang-toggle
				class="nav-item flex items-center gap-1 font-bold text-white hover:text-orange-400 h-8 px-2 rounded-md transition-all"
				aria-label={lang === 'fr' ? 'Switch to English' : 'Changer en Français'}>
				{lang === 'fr' ? 'EN' : 'FR'}
			</a>

			<a href="#contact"
				class="hidden sm:inline-flex items-center gap-1.5 btn btn-orange text-xs py-2 px-4 shadow-none hover:shadow-lg"
				title="Hire Yanis Amani" aria-label="Send an email to Yanis Amani">
				<span class="w-1.5 h-1.5 rounded-full bg-ink animate-pulse"></span>
				{t.hireMe}
			</a>

			<!-- Mobile menu toggle -->
			<button id="mob-btn" type="button" class="md:hidden text-muted hover:text-white transition-colors p-1"
				aria-label="Open menu" aria-expanded="false" aria-controls="mob-menu">
				<svg id="mob-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7h16M4 12h16M4 17h16"/>
				</svg>
			</button>
		</div>
	</div>

	<!-- Mobile menu -->
	<div id="mob-menu"
		class="md:hidden hidden border-t border-border bg-ink/95 backdrop-blur-xl">
		<div class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-0.5 font-mono text-sm">
			<a href="#projects" class="px-3 py-3 text-subtle hover:text-white hover:bg-ink-2 rounded-md transition-colors">#{t.projects}</a>
			<a href="#skills"   class="px-3 py-3 text-subtle hover:text-white hover:bg-ink-2 rounded-md transition-colors">#{t.skills}</a>
			<a href="#contact"  class="px-3 py-3 text-subtle hover:text-white hover:bg-ink-2 rounded-md transition-colors">#{t.contact}</a>
			<a href="https://github.com/DevYatsu" target="_blank" rel="noopener noreferrer"
				class="px-3 py-3 text-[hsl(0,0%,55%)] hover:text-white hover:bg-[hsl(0,0%,10%)] rounded-md transition-colors">{t.github} ↗</a>
			<a href="#contact"
				class="mt-3 btn btn-orange justify-center text-sm">
				{t.hireMe} →
			</a>
		</div>
	</div>
</nav>

<script>
	const btn  = document.getElementById('mob-btn');
	const menu = document.getElementById('mob-menu');
	let open = false;

	btn?.addEventListener('click', () => {
		open = !open;
		btn.setAttribute('aria-expanded', String(open));
		menu?.classList.toggle('hidden', !open);
		menu?.querySelectorAll('a').forEach(a =>
			a.addEventListener('click', () => { open = false; menu?.classList.add('hidden'); }, { once: true })
		);
	});
</script>
