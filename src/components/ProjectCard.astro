---
interface Props {
	project: {
		id: string;
		num: string;
		name: string;
		url?: string;
		tags: string[];
		locales: {
			en: { tagline: string; description: string; status: string };
			fr: { tagline: string; description: string; status: string };
		};
	};
	lang: "en" | "fr";
}

const { project, lang } = Astro.props;
const content = project.locales[lang];
---

<article class="bento-card group h-full structural-border">
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-3">
      <span class="font-mono text-[0.6rem] text-primary/60 font-black">{project.num}</span>
      <div class="h-px w-8 bg-primary/20"></div>
      <span class="tech-label">{content.status}</span>
    </div>
  </div>

  <div class="flex-grow">
    <h3 class="text-2xl font-black mb-2 group-hover:text-primary transition-colors">
      {project.name}
    </h3>
    <p class="font-mono text-[0.65rem] text-primary mb-6 uppercase tracking-wider font-bold">
      {content.tagline}
    </p>
    <p class="text-text-muted text-sm leading-relaxed mb-8">
      {content.description}
    </p>
  </div>

  <div class="mt-auto space-y-6">
    <div class="flex flex-wrap gap-1.5">
      {project.tags.map(tag => (
        <span class="font-mono text-[0.55rem] px-2 py-0.5 border border-border-subtle text-text-dim">
          {tag}
        </span>
      ))}
    </div>

    <div class="flex items-center justify-between pt-6 border-t border-border-subtle">
      {project.url ? (
        <a href={project.url} target="_blank" rel="noopener noreferrer" 
           class="nav-link group/link">
          {lang === 'fr' ? 'VOIR INSTANCE' : 'LIVE INSTANCE'}
          <svg class="w-3 h-3 transition-transform group-hover/link:translate-x-1 group-hover/link:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M7 17L17 7M17 7H7M17 7V17" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ) : (
        <span class="nav-link opacity-30 cursor-not-allowed">
          {lang === 'fr' ? 'CODE PRIVÉ' : 'PRIVATE SOURCE'}
        </span>
      )}
      
      <div class="flex gap-1">
        <div class="w-1 h-1 bg-primary/40"></div>
        <div class="w-1 h-1 bg-primary/20"></div>
        <div class="w-1 h-1 bg-primary/10"></div>
      </div>
    </div>
  </div>
</article>
