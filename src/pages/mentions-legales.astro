---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Mentions Légales & RGPD // Yanis Amani"
  description="Mentions légales et politique de confidentialité du portfolio de Yanis Amani."
  lang="fr"
>
  <section class="py-24 px-6 md:px-12 max-w-4xl mx-auto">
    <!-- Navigation -->
    <a href="/fr" class="nav-link inline-flex items-center gap-2 mb-16" data-animate>
      RETOUR À L'ACCUEIL ↗
    </a>

    <!-- Header -->
    <div class="mb-24" data-animate>
      <span class="tech-label mb-6 inline-block">INFOS LÉGALES</span>
      <h1 class="display-md uppercase font-black mb-6 leading-none">
        MENTIONS LÉGALES &<br/>
        <span class="text-primary italic">CONFIDENTIALITÉ</span>
      </h1>
      <p class="font-mono text-[0.6rem] text-text-dim uppercase tracking-widest">
        DERNIÈRE MAJ // MARS 2026
      </p>
    </div>

    <div class="space-y-24">
      <!-- Section 1: Publisher -->
      <div class="structural-border p-12 bg-bg-surface" data-animate>
        <div class="flex justify-between items-start mb-12">
          <span class="tech-label">SECTION 01 // ÉDITEUR</span>
          <div class="w-12 h-px bg-border-subtle"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="space-y-6">
            <h2 class="text-2xl font-black uppercase tracking-tight">YANIS AMANI</h2>
            <p class="font-mono text-[0.7rem] text-text-muted leading-relaxed uppercase">
              Étudiant en Informatique @ HE-Arc<br/>
              Neuchâtel, Suisse
            </p>
          </div>
          <div class="space-y-6">
            <span class="tech-label block mb-4 w-fit">CONTACT DIRECT</span>
            <a href="mailto:yanis.amani@icloud.com" class="text-xl font-black text-primary hover:text-primary-dark transition-colors break-all">
              YANIS.AMANI@ICLOUD.COM
            </a>
          </div>
        </div>
      </div>

      <!-- Section 2: Privacy -->
      <div class="structural-border p-12 bg-bg-surface" data-animate>
        <div class="flex justify-between items-start mb-12">
          <span class="tech-label">SECTION 02 // VIE PRIVÉE</span>
          <div class="w-12 h-px bg-border-subtle"></div>
        </div>
        <div class="space-y-8">
          <h2 class="text-2xl font-black uppercase tracking-tight">POLITIQUE CONFIDENTIALITÉ</h2>
          <p class="text-text-muted leading-relaxed">
            Ce site est conçu dans le respect de votre vie privée. Aucun cookie de traçage n'est utilisé, et aucun script d'analyse tiers n'est actif.
          </p>
          <div class="p-6 border border-primary/20 bg-primary/5">
            <h3 class="font-bold uppercase text-xs mb-4 text-primary">VOS DROITS</h3>
            <p class="text-sm text-text-muted font-mono leading-relaxed uppercase">
              Vous disposez d'un droit d'accès, de modification et d'effacement de toute information transmise via les canaux officiels.
            </p>
          </div>
        </div>
      </div>

      <!-- Section 3: Hosting -->
      <div class="structural-border p-12 bg-bg-surface" data-animate>
        <div class="flex justify-between items-start mb-12">
          <span class="tech-label">SECTION 03 // HÉBERGEMENT</span>
          <div class="w-12 h-px bg-border-subtle"></div>
        </div>
        <div class="space-y-4">
          <h2 class="text-xl font-black uppercase">NETLIFY INC</h2>
          <p class="font-mono text-[0.7rem] text-text-muted uppercase">
            44 MONTGOMERY ST, SAN FRANCISCO, CA 94104
          </p>
        </div>
      </div>
    </div>

    <!-- Footer link -->
    <div class="mt-32 pt-12 border-t border-border-subtle text-center">
      <a href="/fr" class="btn-arch inline-flex">
        RETOUR À L'ACCUEIL
      </a>
    </div>
  </section>
</Layout>
