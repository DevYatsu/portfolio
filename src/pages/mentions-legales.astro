---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Mentions Légales & RGPD // Yanis Amani"
  description="Mentions légales, politique de confidentialité et RGPD pour le portfolio de Yanis Amani. Aucun cookie de traçage, aucun analytics tiers — conçu pour respecter votre vie privée."
  canonical="/impressum"
>
  <section data-lang="en">
    <article class="legal-page" data-animate>
      <div class="container">
        <a href="/" class="legal-back">← Back to Home</a>

        <div class="legal-header">
          <span class="legal-tag">Legal Info</span>
          <h1 class="legal-title">
            Impressum &<br/>
            <span class="legal-accent">Privacy Policy</span>
          </h1>
          <p class="legal-date">Last Update — July 2026</p>
        </div>

        <div class="legal-sections">
          <div class="legal-section" data-animate>
            <div class="legal-section-grid">
              <div>
                <h2 class="legal-h2">Yanis Amani</h2>
                <p class="legal-p">Computer Science Student @ HE-Arc<br/>Neuchâtel, Switzerland</p>
              </div>
              <div>
                <span class="legal-field-label">Contact Direct</span>
                <a href="mailto:yanis.amani@icloud.com" class="legal-email">yanis.amani@icloud.com</a>
              </div>
            </div>
          </div>

          <div class="legal-section" data-animate>
            <h2 class="legal-h2">Privacy First Policy</h2>
            <p class="legal-p">This website is built with privacy in mind. No tracking cookies are used, and no third-party analytics are active.</p>
            <div class="legal-highlight">
              <h3 class="legal-highlight-label">Your Rights</h3>
              <p class="legal-p">You have the right to access, change, or delete any personal information sent through official channels.</p>
            </div>
          </div>

          <div class="legal-section" data-animate>
            <h2 class="legal-h2">Infomaniak Network SA</h2>
            <p class="legal-p">Rue Eugène-Marziano 25, 1227 Les Acacias, Switzerland</p>
          </div>
        </div>

        <div class="legal-footer">
          <a href="/" class="btn-primary">Back to Home</a>
        </div>
      </div>
    </article>
  </section>

  <section data-lang="fr">
    <article class="legal-page" data-animate>
      <div class="container">
        <a href="/" class="legal-back">← Retour à l'accueil</a>

        <div class="legal-header">
          <span class="legal-tag">Infos Légales</span>
          <div class="legal-title" role="presentation">
            Mentions légales &<br/>
            <span class="legal-accent">Confidentialité</span>
          </div>
          <p class="legal-date">Dernière mise à jour — Juillet 2026</p>
        </div>

        <div class="legal-sections">
          <div class="legal-section" data-animate>
            <div class="legal-section-grid">
              <div>
                <h2 class="legal-h2">Yanis Amani</h2>
                <p class="legal-p">Étudiant en Informatique @ HE-Arc<br/>Neuchâtel, Suisse</p>
              </div>
              <div>
                <span class="legal-field-label">Contact Direct</span>
                <a href="mailto:yanis.amani@icloud.com" class="legal-email">yanis.amani@icloud.com</a>
              </div>
            </div>
          </div>

          <div class="legal-section" data-animate>
            <h2 class="legal-h2">Politique Confidentialité</h2>
            <p class="legal-p">Ce site est conçu dans le respect de votre vie privée. Aucun cookie de traçage n'est utilisé, et aucun script d'analyse tiers n'est actif.</p>
            <div class="legal-highlight">
              <h3 class="legal-highlight-label">Vos Droits</h3>
              <p class="legal-p">Vous disposez d'un droit d'accès, de modification et d'effacement de toute information transmise via les canaux officiels.</p>
            </div>
          </div>

          <div class="legal-section" data-animate>
            <h2 class="legal-h2">Infomaniak Network SA</h2>
            <p class="legal-p">Rue Eugène-Marziano 25, 1227 Les Acacias, Suisse</p>
          </div>
        </div>

        <div class="legal-footer">
          <a href="/" class="btn-primary">Retour à l'accueil</a>
        </div>
      </div>
    </article>
  </section>
</Layout>

<style>
.legal-page {
  padding-top: 8rem;
  padding-bottom: var(--space-2xl);
}

.legal-back {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-muted);
  text-decoration: none;
  margin-bottom: var(--space-xl);
  transition: color var(--dur-short) var(--ease-out);
}
.legal-back:hover { color: var(--color-accent); }

.legal-header {
  margin-bottom: var(--space-2xl);
}

.legal-tag {
  display: block;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-accent);
  font-weight: 500;
  margin-bottom: var(--space-sm);
}

.legal-title {
  font-family: var(--font-display);
  font-size: var(--text-display-s);
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 0.95;
  margin-bottom: var(--space-sm);
}

.legal-accent {
  color: var(--color-accent);
  font-style: normal;
}

.legal-date {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-muted);
}

.legal-sections {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.legal-section {
  padding: var(--space-lg);
  border: 1px solid var(--color-rule);
  border-radius: var(--radius-lg);
  background: var(--color-paper-2);
}

@media (min-width: 768px) {
  .legal-section { padding: var(--space-xl); }
}

.legal-section-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-lg);
}

@media (min-width: 768px) {
  .legal-section-grid { grid-template-columns: 1fr 1fr; }
}

.legal-h2 {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 600;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-sm);
}

.legal-p {
  font-size: var(--text-sm);
  color: var(--color-ink-2);
  line-height: 1.65;
  font-family: var(--font-body);
}

.legal-field-label {
  display: block;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-muted);
  margin-bottom: var(--space-2xs);
  letter-spacing: 0.05em;
}

.legal-email {
  font-size: var(--text-base);
  font-weight: 500;
  color: var(--color-accent);
  text-decoration: none;
  transition: opacity var(--dur-short) var(--ease-out);
  word-break: break-all;
}
.legal-email:hover { opacity: 0.75; }

.legal-highlight {
  padding: var(--space-md);
  border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
  background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  border-radius: var(--radius-md);
  margin-top: var(--space-md);
}

.legal-highlight-label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-accent);
  margin-bottom: var(--space-2xs);
}

.legal-footer {
  margin-top: var(--space-2xl);
  padding-top: var(--space-xl);
  border-top: 1px solid var(--color-rule);
  text-align: center;
}
</style>
