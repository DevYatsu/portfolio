---
import Layout from '../layouts/Layout.astro';

const lang = 'en';
const content = {
  title: "Thank You — Yanis Amani",
  description: "Message sent successfully.",
  heading: "Message sent.",
  subheading: "Thank you for reaching out. I'll get back to you as soon as possible.",
  cta: "Back to Home",
  bg: "THANKS"
};
---

<Layout
  title={content.title}
  description={content.description}
  lang={lang}
>
  <section class="relative min-h-[80vh] flex flex-col items-center justify-center text-center px-6 overflow-hidden">
    <div aria-hidden="true" 
      class="absolute inset-0 flex items-center justify-center select-none pointer-events-none overflow-hidden">
      <span class="font-black text-gray-dark whitespace-nowrap opacity-20"
        style="font-size: clamp(8rem, 25vw, 25rem); letter-spacing: -0.05em; line-height: 1;">
        {content.bg}
      </span>
    </div>

    <div class="relative z-10 max-w-2xl" data-animate>
      <div class="mb-8 flex justify-center">
        <div class="w-16 h-16 rounded-full border border-orange flex items-center justify-center text-orange">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
      </div>
      
      <h1 class="display-lg text-white mb-6">
        {content.heading}
      </h1>
      <p class="text-muted text-lg mb-12 max-w-md mx-auto leading-relaxed">
        {content.subheading}
      </p>
      
      <a href="/" class="btn btn-orange">
        <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
        {content.cta}
      </a>
    </div>
  </section>
</Layout>
