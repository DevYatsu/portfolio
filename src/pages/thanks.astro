---
import Layout from "../layouts/Layout.astro";

const content = {
  title: "Message Received // Yanis Amani",
  description: "Thanks for reaching out! Your message has been sent successfully. I'll get back to you within a day or two.",
  heading: "MESSAGE RECEIVED",
  subheading: "Thanks for reaching out! I'll get back to you as soon as I can — usually within a day or two.",
  cta: "Back to Home",
};
---

<Layout title={content.title} description={content.description} noindex={true}>
  <section class="confirm-page" data-animate>
    <div class="confirm-card">
      <span class="confirm-badge">Success</span>
      <h1 class="confirm-title">
        Message<br/>
        <span class="confirm-accent">received.</span>
      </h1>
      <p class="confirm-desc">{content.subheading}</p>
      <a href="/" class="btn-primary">{content.cta}</a>
    </div>
  </section>
</Layout>

<style>
.confirm-page {
  min-height: 80vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: var(--space-2xl) var(--space-md);
  text-align: center;
}

.confirm-card {
  max-width: 28rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-lg);
}

.confirm-badge {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-accent);
  letter-spacing: 0.08em;
}

.confirm-title {
  font-size: var(--text-display);
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 0.92;
}

.confirm-accent {
  color: var(--color-accent);
  font-style: normal;
}

.confirm-desc {
  font-size: var(--text-base);
  color: var(--color-muted);
  line-height: 1.6;
  max-width: 24rem;
  font-family: var(--font-body);
}
</style>
