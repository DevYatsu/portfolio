---
import Layout from "../layouts/Layout.astro";

const lang = "en";
const content = {
	title: "Message Received // Yanis Amani",
	description: "Your message has been successfully sent.",
	heading: "MESSAGE RECEIVED",
	subheading:
		"Thank you for reaching out. I have received your message and will get back to you as soon as possible.",
	cta: "BACK TO HOME",
};
---

<Layout title={content.title} description={content.description} lang={lang}>
  <section class="min-h-[80vh] flex flex-col justify-center items-center px-6 py-24 max-w-7xl mx-auto">
    <div class="text-center space-y-12" data-animate>
      <div class="inline-flex items-center gap-4">
        <span class="tech-label">SUCCESS</span>
        <div class="h-px w-12 bg-primary/30"></div>
        <span class="font-mono text-[0.6rem] text-text-dim uppercase tracking-widest font-black">MESSAGE SENT</span>
      </div>

      <h1 class="display-title leading-[0.8] tracking-tighter">
        MESSAGE<br/>
        <span class="text-primary">RECEIVED.</span>
      </h1>

      <div class="max-w-xl mx-auto structural-border p-8 bg-bg-surface text-left">
        <div class="flex justify-between items-start mb-6">
          <span class="tech-label">CONFIRMATION</span>
          <span class="text-primary font-mono text-[0.6rem]">STATUS OK</span>
        </div>
        <p class="font-mono text-[0.7rem] text-text-muted leading-relaxed mb-8">
          {content.subheading}
        </p>
        <div class="flex flex-col gap-4">
          <div class="flex justify-between border-b border-border-subtle pb-2 font-mono text-[0.6rem]">
            <span class="text-text-dim">SECURITY</span>
            <span class="text-text-main font-bold">ENCRYPTED</span>
          </div>
          <div class="flex justify-between border-b border-border-subtle pb-2 font-mono text-[0.6rem]">
            <span class="text-text-dim">RECIPIENT</span>
            <span class="text-text-main font-bold">YANIS AMANI</span>
          </div>
        </div>
      </div>

      <a href="/" class="btn-arch inline-flex mx-auto">
        {content.cta}
      </a>
    </div>
  </section>
</Layout>
