---
import Layout from "../layouts/Layout.astro";

const lang = "fr";
const content = {
	title: "Message Reçu // Yanis Amani",
	description: "Votre message a été envoyé avec succès.",
	heading: "MESSAGE REÇU",
	subheading:
		"Merci de m'avoir contacté. J'ai bien reçu votre message et je vous répondrai dans les plus brefs délais.",
	cta: "RETOUR À L'ACCUEIL",
};
---

<Layout title={content.title} description={content.description} lang={lang}>
  <section class="min-h-[80vh] flex flex-col justify-center items-center px-6 py-24 max-w-7xl mx-auto">
    <div class="text-center space-y-12" data-animate>
      <div class="inline-flex items-center gap-4">
        <span class="tech-label">SUCCÈS</span>
        <div class="h-px w-12 bg-primary/30"></div>
        <span class="font-mono text-[0.6rem] text-text-dim uppercase tracking-widest font-black">MESSAGE ENVOYÉ</span>
      </div>

      <h1 class="display-title leading-[0.8] tracking-tighter">
        MESSAGE<br/>
        <span class="text-primary">REÇU.</span>
      </h1>

      <div class="max-w-xl mx-auto structural-border p-8 bg-bg-surface text-left">
        <div class="flex justify-between items-start mb-6">
          <span class="tech-label">CONFIRMATION</span>
          <span class="text-primary font-mono text-[0.6rem]">STATUS OK</span>
        </div>
        <p class="font-mono text-[0.7rem] text-text-muted leading-relaxed mb-8">
          {content.subheading}
        </p>
        <div class="flex flex-col gap-4">
          <div class="flex justify-between border-b border-border-subtle pb-2 font-mono text-[0.6rem]">
            <span class="text-text-dim">SÉCURITÉ</span>
            <span class="text-text-main font-bold">CHIFFRÉ</span>
          </div>
          <div class="flex justify-between border-b border-border-subtle pb-2 font-mono text-[0.6rem]">
            <span class="text-text-dim">DESTINATAIRE</span>
            <span class="text-text-main font-bold">YANIS AMANI</span>
          </div>
        </div>
      </div>

      <a href="/fr" class="btn-arch inline-flex mx-auto">
        {content.cta}
      </a>
    </div>
  </section>
</Layout>
