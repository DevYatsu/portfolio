---
import Layout from "../layouts/Layout.astro";

const content = {
  title: "Message Reçu // Yanis Amani",
  description: "Votre message a été envoyé avec succès.",
  heading: "MESSAGE REÇU",
  subheading: "Merci de m'avoir écrit ! Je réponds généralement sous un jour ou deux — promis.",
  cta: "Retour à l'accueil",
};
---

<Layout title={content.title} description={content.description}>
  <section class="confirm-page" data-animate>
    <div class="confirm-card">
      <div class="confirm-top">
        <span class="confirm-badge">Succès</span>
        <span class="confirm-sep"></span>
        <span class="confirm-label">Message Envoyé</span>
      </div>

      <h1 class="confirm-title">
        MESSAGE<br/>
        <span class="confirm-accent">REÇU.</span>
      </h1>

      <div class="confirm-box">
        <div class="confirm-box-top">
          <span class="confirm-box-label">Confirmation</span>
          <span class="confirm-status">Statut OK</span>
        </div>
        <p class="confirm-desc">{content.subheading}</p>
        <div class="confirm-details">
          <div class="confirm-row">
            <span class="confirm-key">Sécurité</span>
            <span class="confirm-val">Chiffré</span>
          </div>
          <div class="confirm-row">
            <span class="confirm-key">Destinataire</span>
            <span class="confirm-val">Yanis Amani</span>
          </div>
        </div>
      </div>

      <a href="/" class="btn-primary" style="margin-inline: auto;">{content.cta}</a>
    </div>
  </section>
</Layout>

<style>
  .confirm-page {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 6rem 1.5rem;
    text-align: center;
  }
  .confirm-card { max-width: 32rem; display: flex; flex-direction: column; gap: 2.5rem; }
  .confirm-top { display: flex; align-items: center; gap: 1rem; justify-content: center; }
  .confirm-badge { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--accent); font-weight: 500; }
  .confirm-sep { width: 1.5rem; height: 1px; background: rgba(59, 130, 246, 0.3); }
  .confirm-label { font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-dim); }
  .confirm-title { font-size: clamp(2.5rem, 6vw, 4rem); letter-spacing: -0.03em; line-height: 0.9; }
  .confirm-accent { font-style: italic; color: var(--accent); }
  .confirm-box { border: 1px solid var(--border); border-radius: 8px; padding: 2rem; background: var(--surface); text-align: left; }
  .confirm-box-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.25rem; }
  .confirm-box-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--text-dim); }
  .confirm-status { font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent); }
  .confirm-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1.5rem; }
  .confirm-details { display: flex; flex-direction: column; gap: 0.75rem; border-top: 1px solid var(--border); padding-top: 1rem; }
  .confirm-row { display: flex; justify-content: space-between; font-size: 0.65rem; }
  .confirm-key { color: var(--text-dim); }
  .confirm-val { color: var(--text); font-weight: 500; }
</style>
