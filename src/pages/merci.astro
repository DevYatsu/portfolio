---
import Layout from "../layouts/Layout.astro";

const content = {
  title: "Message Reçu // Yanis Amani",
  description: "Votre message a été envoyé avec succès.",
  heading: "MESSAGE REÇU",
  subheading: "Merci de m'avoir écrit ! Je réponds généralement sous un jour ou deux — promis.",
  cta: "Retour à l'accueil",
};
---

<Layout title={content.title} description={content.description}>
  <section class="confirm-page" data-animate>
    <div class="confirm-card">
      <span class="confirm-badge">Succès</span>
      <h1 class="confirm-title">
        Message<br/>
        <span class="confirm-accent">reçu.</span>
      </h1>
      <p class="confirm-desc">{content.subheading}</p>
      <a href="/" class="btn-primary">{content.cta}</a>
    </div>
  </section>
</Layout>

<style>
.confirm-page {
  min-height: 80vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: var(--space-2xl) var(--space-md);
  text-align: center;
}

.confirm-card {
  max-width: 28rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-lg);
}

.confirm-badge {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-accent);
  letter-spacing: 0.08em;
}

.confirm-title {
  font-size: var(--text-display);
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 0.92;
}

.confirm-accent {
  color: var(--color-accent);
  font-style: normal;
}

.confirm-desc {
  font-size: var(--text-base);
  color: var(--color-muted);
  line-height: 1.6;
  max-width: 24rem;
  font-family: var(--font-body);
}
</style>
