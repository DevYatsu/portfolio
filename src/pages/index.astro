---
import Layout from "../layouts/Layout.astro";
import { projects, staticSites, skills } from "../data/portfolio";
---

<Layout title="Yanis Amani // CS Student | Étudiant en Informatique">
  <!-- ═══════ ENGLISH ═══════ -->
  <section data-lang="en">

    <!-- MARQUEE HERO -->
    <section class="marquee-hero">
      <div class="container marquee-hero__inner">
        <span class="marquee-hero__badge">CS Student · Systems · Web · Reliability</span>
        <h1 class="marquee-hero__title">Yanis <span class="marquee-hero__accent">Amani</span></h1>
        <p class="marquee-hero__desc">I build reliable software. Rust, TypeScript, systems programming — the kind that doesn't fall over in production.</p>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- PROJECTS -->
    <section id="projects" class="section marquee-section">
      <div class="container">
        <div class="section__head" data-animate>
          <h2 class="section__title">Projects</h2>
          <p class="section__sub">Side projects, open-source tools, and things I built because they were interesting problems.</p>
        </div>
        <div class="project-grid" data-animate>
          {projects.map((p) => (
            <a href={`/projects/${p.id}`} class="project-card" aria-label={p.name}>
              <span class="project-card__cat">{p.category.en}</span>
              <h3 class="project-card__name">{p.name}</h3>
              <p class="project-card__desc">{p.description.en}</p>
              <div class="project-card__tags">
                {p.tags.map((tag) => (
                  <a href={tag.url} target="_blank" rel="noopener noreferrer" class="tech-tag">{tag.name}</a>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- STATIC SITES -->
    <section class="section marquee-section">
      <div class="container">
        <div class="section__head" data-animate>
          <h2 class="section__title">Static Sites</h2>
          <p class="section__sub">Client projects — clean, professional web presence.</p>
        </div>
        <div class="static-grid" data-animate>
          {staticSites.map((site) => (
            <a href={site.url} target="_blank" rel="noopener noreferrer" class="static-card">
              <h3 class="static-card__name">{site.name}</h3>
              <p class="static-card__desc">{site.description.en}</p>
              <div class="static-card__tags">
                {site.tags.map((tag) => (
                  <span class="mini-tag">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- SKILLS -->
    <section id="skills" class="section marquee-section">
      <div class="container container--narrow">
        <div class="section__head" data-animate>
          <h2 class="section__title">Skills</h2>
          <p class="section__sub">Languages and frameworks I reach for daily.</p>
        </div>
        <div class="skills-filter" data-animate>
          <button class="filter-btn active" data-filter="all">All</button>
          <button class="filter-btn" data-filter="lang">Languages</button>
          <button class="filter-btn" data-filter="frontend">Frontend</button>
          <button class="filter-btn" data-filter="backend">Backend</button>
          <button class="filter-btn" data-filter="systems">Systems</button>
        </div>
        <div class="skills-pool" data-animate>
          {skills.map((s) => (
            <span class="skill-chip" data-category={s.category}>{s.name}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="section marquee-section">
      <div class="container container--narrow">
        <div class="section__head" data-animate>
          <h2 class="section__title">Approach</h2>
          <p class="section__sub">How I think about building software.</p>
        </div>
        <div class="about-body" data-animate>
          <p class="about-text">I care about the boring stuff. Good error handling, clean interfaces, code that's still readable six months later. I've broken enough things in production to know that "it works on my machine" is not a testing strategy. These days I'd rather go slow and get it right.</p>
          <div class="values-row">
            <span class="value-chip">Reliability</span>
            <span class="value-chip">Performance</span>
            <span class="value-chip">Security</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- CONTACT -->
    <section id="contact" class="section marquee-section">
      <div class="container container--narrow">
        <div class="contact-card" data-animate>
          <h2 class="contact-card__title">Get in Touch</h2>
          <p class="contact-card__sub">Got a project, an idea, or just want to chat? I'm around.</p>
          <div class="contact-card__body">
            <a href="mailto:yanis.amani@icloud.com" class="contact-card__email">yanis.amani@icloud.com</a>
            <div class="contact-card__socials">
              <a href="https://linkedin.com/in/yanis-amani" target="_blank" class="contact-card__social">LinkedIn</a>
              <a href="https://github.com/DevYatsu" target="_blank" class="contact-card__social">GitHub</a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </section>

  <!-- ═══════ FRENCH ═══════ -->
  <section data-lang="fr">

    <!-- MARQUEE HERO -->
    <section class="marquee-hero">
      <div class="container marquee-hero__inner">
        <span class="marquee-hero__badge">Étudiant en Informatique · Systèmes · Web · Fiabilité</span>
        <h1 class="marquee-hero__title">Yanis <span class="marquee-hero__accent">Amani</span></h1>
        <p class="marquee-hero__desc">Je construis des logiciels fiables. Rust, TypeScript, programmation système — le genre qui tient la route en production.</p>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- PROJETS -->
    <section id="projects" class="section marquee-section">
      <div class="container">
        <div class="section__head" data-animate>
          <h2 class="section__title">Projets</h2>
          <p class="section__sub">Projets perso, outils open-source, des trucs construits parce que le problème était intéressant.</p>
        </div>
        <div class="project-grid" data-animate>
          {projects.map((p) => (
            <a href={`/projects/${p.id}`} class="project-card" aria-label={p.name}>
              <span class="project-card__cat">{p.category.fr}</span>
              <h3 class="project-card__name">{p.name}</h3>
              <p class="project-card__desc">{p.description.fr}</p>
              <div class="project-card__tags">
                {p.tags.map((tag) => (
                  <a href={tag.url} target="_blank" rel="noopener noreferrer" class="tech-tag">{tag.name}</a>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- SITES STATIQUES -->
    <section class="section marquee-section">
      <div class="container">
        <div class="section__head" data-animate>
          <h2 class="section__title">Sites statiques</h2>
          <p class="section__sub">Projets clients — présence web propre et professionnelle.</p>
        </div>
        <div class="static-grid" data-animate>
          {staticSites.map((site) => (
            <a href={site.url} target="_blank" rel="noopener noreferrer" class="static-card">
              <h3 class="static-card__name">{site.name}</h3>
              <p class="static-card__desc">{site.description.fr}</p>
              <div class="static-card__tags">
                {site.tags.map((tag) => (
                  <span class="mini-tag">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- COMPÉTENCES -->
    <section id="skills" class="section marquee-section">
      <div class="container container--narrow">
        <div class="section__head" data-animate>
          <h2 class="section__title">Compétences</h2>
          <p class="section__sub">Langages et frameworks que j'utilise quotidiennement.</p>
        </div>
        <div class="skills-filter" data-animate>
          <button class="filter-btn active" data-filter="all">Tous</button>
          <button class="filter-btn" data-filter="lang">Langages</button>
          <button class="filter-btn" data-filter="frontend">Frontend</button>
          <button class="filter-btn" data-filter="backend">Backend</button>
          <button class="filter-btn" data-filter="systems">Système</button>
        </div>
        <div class="skills-pool" data-animate>
          {skills.map((s) => (
            <span class="skill-chip" data-category={s.category}>{s.name}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- APPROCHE -->
    <section id="about" class="section marquee-section">
      <div class="container container--narrow">
        <div class="section__head" data-animate>
          <h2 class="section__title">Approche</h2>
          <p class="section__sub">Comment je pense le développement logiciel.</p>
        </div>
        <div class="about-body" data-animate>
          <p class="about-text">Je me soucie des trucs ennuyeux. La gestion d'erreurs propre, des interfaces claires, du code qui se relit encore six mois après. J'ai assez cassé de choses en production pour savoir que « ça marche sur ma machine » n'est pas une stratégie de test. Maintenant je préfère aller lentement mais bien faire les choses.</p>
          <div class="values-row">
            <span class="value-chip">Fiabilité</span>
            <span class="value-chip">Performance</span>
            <span class="value-chip">Sécurité</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- CONTACT -->
    <section id="contact" class="section marquee-section">
      <div class="container container--narrow">
        <div class="contact-card" data-animate>
          <h2 class="contact-card__title">Me contacter</h2>
          <p class="contact-card__sub">Un projet, une idée, ou juste envie de parler ? Je suis là.</p>
          <div class="contact-card__body">
            <a href="mailto:yanis.amani@icloud.com" class="contact-card__email">yanis.amani@icloud.com</a>
            <div class="contact-card__socials">
              <a href="https://linkedin.com/in/yanis-amani" target="_blank" class="contact-card__social">LinkedIn</a>
              <a href="https://github.com/DevYatsu" target="_blank" class="contact-card__social">GitHub</a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </section>
</Layout>

<!-- Scripts (same as current — keep these exactly) -->
<script is:inline data-astro-rerun>
  window.__setLanguage = (function() {
    var orig = window.__setLanguage;
    return function(lang) {
      if (orig) orig(lang);
      document.querySelectorAll('.skill-chip').forEach(function(el) { el.style.display = ''; });
      document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
      var visibleAll = document.querySelector('section[data-lang="' + lang + '"] .filter-btn[data-filter="all"]');
      if (visibleAll) visibleAll.classList.add('active');
      if (window.__revealAnimations) window.__revealAnimations();
      if (window.__filterSkills) window.__filterSkills();
    };
  })();
</script>

<script>
  window.__filterSkills = function() {
    var active = document.querySelector('.filter-btn.active');
    var chips = document.querySelectorAll('.skill-chip');
    var filterVal = active ? active.dataset.filter : 'all';
    chips.forEach(function(chip) {
      var section = chip.closest('[data-lang]');
      if (!section || section.offsetParent === null) return;
      chip.style.display = (filterVal === 'all' || chip.dataset.category === filterVal) ? '' : 'none';
    });
  };

  window.__revealAnimations = function() {
    document.querySelectorAll('[data-animate]').forEach(function(el) {
      if (el.offsetParent !== null) el.classList.add('visible');
    });
  };

  document.addEventListener('astro:page-load', function() {
    document.querySelectorAll('.filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        window.__filterSkills();
      });
    });

    document.addEventListener('click', function(e) {
      var link = e.target.closest('a[href^="#"]:not([href="#"])');
      if (!link) return;
      var id = link.getAttribute('href').substring(1);
      var candidates = document.querySelectorAll('[id="' + id + '"]');
      if (candidates.length <= 1) return;
      e.preventDefault();
      var el = null;
      for (var i = 0; i < candidates.length; i++) {
        if (candidates[i].offsetParent !== null) { el = candidates[i]; break; }
      }
      if (!el) el = document.getElementById(id);
      if (!el) return;
      history.replaceState(null, '', link.getAttribute('href'));
      var top = el.getBoundingClientRect().top + window.scrollY - 96;
      window.scrollTo({ top: top, behavior: 'smooth' });
    });
  });
</script>

<style>
/* ═══════════════════════════════════════════
   Hallmark · genre: modern-minimal · macrostructure: Marquee Hero
   design-system: design.md · designed-as-app
   pre-emit critique: P5 H4 E4 S4 R4 V5
   ═══════════════════════════════════════════ */

/* ── Marquee Hero ── */
.marquee-hero {
  min-height: 85vh;
  display: flex;
  align-items: center;
  position: relative;
}

.marquee-hero__inner {
  position: relative;
  z-index: 1;
  width: 100%;
}

.marquee-hero__badge {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-accent);
  margin-bottom: var(--space-md);
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

.marquee-hero__title {
  font-size: clamp(3.25rem, 8vw + 0.5rem, 6.5rem);
  font-weight: 700;
  letter-spacing: -0.035em;
  line-height: 0.9;
  margin-bottom: var(--space-md);
  max-width: 8ch;
  overflow-wrap: anywhere;
  min-width: 0;
}

.marquee-hero__accent {
  color: var(--color-accent);
  font-style: normal;
}

.marquee-hero__desc {
  font-size: var(--text-md);
  color: var(--color-muted);
  line-height: 1.65;
  max-width: 34rem;
  font-family: var(--font-body);
  margin-bottom: 0;
}

@media (min-width: 768px) {
  .marquee-hero__desc { font-size: var(--text-lg); }
  .marquee-hero__title { font-size: clamp(4rem, 8vw + 0.5rem, 7rem); }
}

/* ── Section Headers ── */
.section__head {
  margin-bottom: var(--space-lg);
}

.section__title {
  font-size: var(--text-2xl);
  font-weight: 600;
  margin-bottom: var(--space-2xs);
}

.section__sub {
  font-size: var(--text-base);
  color: var(--color-muted);
  max-width: 32rem;
  line-height: 1.6;
  font-family: var(--font-body);
}

/* ── Project Cards ── */
.project-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-md);
}

@media (min-width: 768px) {
  .project-grid {
    grid-template-columns: 1fr 1fr;
  }
}

.project-card {
  display: flex;
  flex-direction: column;
  padding: var(--space-lg);
  border: 1px solid var(--color-rule);
  border-radius: var(--radius-lg);
  background: var(--color-paper-2);
  text-decoration: none;
  color: inherit;
  transition: border-color var(--dur-short) var(--ease-out), box-shadow var(--dur-short) var(--ease-out), transform var(--dur-short) var(--ease-out);
}

.project-card:hover {
  border-color: var(--color-accent);
  box-shadow: 0 2px 20px color-mix(in srgb, var(--color-accent) 8%, transparent);
  transform: translateY(-2px);
}

.project-card__cat {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-muted);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: var(--space-2xs);
}

.project-card__name {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 600;
  margin-bottom: var(--space-2xs);
  letter-spacing: -0.02em;
}

@media (min-width: 768px) {
  .project-card__name { font-size: var(--text-2xl); }
}

.project-card__desc {
  font-size: var(--text-sm);
  color: var(--color-muted);
  line-height: 1.6;
  margin-bottom: var(--space-sm);
  font-family: var(--font-body);
}

.project-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2xs);
  margin-top: auto;
}

/* ── Static Sites Grid ── */
.static-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1px;
  background: var(--color-rule);
  border: 1px solid var(--color-rule);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

@media (min-width: 640px) {
  .static-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .static-grid { grid-template-columns: repeat(3, 1fr); }
}

.static-card {
  display: flex;
  flex-direction: column;
  padding: var(--space-md);
  background: var(--color-paper);
  text-decoration: none;
  color: inherit;
  transition: background var(--dur-short) var(--ease-out);
}

.static-card:hover {
  background: var(--color-paper-2);
}

.static-card__name {
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 600;
  margin-bottom: var(--space-2xs);
}

.static-card__desc {
  font-size: var(--text-sm);
  color: var(--color-muted);
  line-height: 1.5;
  margin-bottom: var(--space-sm);
  font-family: var(--font-body);
}

.static-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2xs);
  margin-top: auto;
}

/* ── Skills Filter ── */
.skills-filter {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2xs);
  margin-bottom: var(--space-md);
}

.skills-pool {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2xs);
}

/* ── About ── */
.about-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.about-text {
  font-size: var(--text-md);
  color: var(--color-ink-2);
  line-height: 1.7;
  font-family: var(--font-body);
  max-width: 48rem;
}

@media (min-width: 768px) {
  .about-text { font-size: var(--text-lg); }
}

.values-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.value-chip {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 600;
  padding: var(--space-2xs) var(--space-sm);
  border: 1px solid var(--color-rule);
  border-radius: var(--radius-pill);
  color: var(--color-ink);
  background: var(--color-paper-2);
}

/* ── Contact ── */
.contact-card {
  padding: var(--space-xl) 0;
}

.contact-card__title {
  font-size: var(--text-2xl);
  margin-bottom: var(--space-2xs);
}

.contact-card__sub {
  font-size: var(--text-base);
  color: var(--color-muted);
  margin-bottom: var(--space-lg);
  font-family: var(--font-body);
}

.contact-card__body {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  align-items: flex-start;
}

.contact-card__email {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 500;
  color: var(--color-accent);
  text-decoration: none;
  transition: opacity var(--dur-short) var(--ease-out);
}

.contact-card__email:hover {
  opacity: 0.75;
}

.contact-card__email:focus-visible {
  outline: 2px solid var(--color-focus);
  outline-offset: 2px;
}

.contact-card__socials {
  display: flex;
  gap: var(--space-md);
}

.contact-card__social {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--color-ink-2);
  text-decoration: none;
  transition: color var(--dur-short) var(--ease-out);
}

.contact-card__social:hover {
  color: var(--color-accent);
}

/* ── Responsive tweaks ── */
@media (max-width: 767px) {
  .marquee-hero__title {
    font-size: clamp(2.5rem, 10vw, 3.75rem);
  }
}
</style>
