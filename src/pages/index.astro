					))}
				</div>
			</div>
		</section>

		<!-- ═══ ABOUT ═══ -->
		<section id="about" class="section-pad" style="border-top: 1px solid var(--border);">
			<div class="container">
				<div class="section-header" data-animate>
					<h2>Mon approche</h2>
					<p class="sub">J'essaie d'écrire du code qui ne me fait pas honte six mois après.</p>
