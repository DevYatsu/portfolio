---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    id: 'kora',
    num: '01',
    name: 'Kora',
    tagline: 'Real-time messaging, zero flicker',
    description: 'Production-ready chat app with fully optimistic UI, Supabase real-time subscriptions, and zero visible latency. Built to handle edge cases most devs never think about.',
    url: 'https://yatsu-kora.netlify.app',
    tags: ['React', 'TypeScript', 'Supabase'],
    status: 'Live ↗',
    statusColor: 'chip-orange',
    span: 'lg:col-span-2',
    accentVar: '--accent: hsl(230,80%,65%)',
    accentHsl: '230,80%,65%',
  },
  {
    id: 'express-rs',
    num: '02',
    name: 'express_rs',
    tagline: 'Express.js, reborn in Rust',
    description: 'A memory-safe, blazing-fast HTTP framework for Rust. Inspired by Express.js, built for maximum concurrency and zero-cost abstractions.',
    url: null,
    tags: ['Rust', 'HTTP', 'TCP', 'Multithreading'],
    status: 'OSS',
    statusColor: '',
    span: '',
    accentVar: '--accent: hsl(14,95%,58%)',
    accentHsl: '14,95%,58%',
  },
  {
    id: 'small-jit',
    num: '03',
    name: 'SmallJIT',
    tagline: 'Machine code from scratch',
    description: 'A JIT compiler written in C++. Direct x86-64 codegen, register allocation, memory mapping — no external libs, pure low-level craft.',
    url: 'https://github.com/DevYatsu/small_jit',
    tags: ['C++', 'x86-64', 'Assembly'],
    status: 'Systems',
    statusColor: '',
    span: '',
    accentVar: '--accent: hsl(0,80%,62%)',
    accentHsl: '0,80%,62%',
  },
  {
    id: 'car-rental',
    num: '04',
    name: 'CarFlow',
    tagline: 'Full-stack vehicle rental platform',
    description: 'Complete rental system: booking flow, live availability, auth, admin dashboard. Full-stack from database schema to responsive UI.',
    url: null,
    tags: ['Full Stack', 'API Design', 'Auth'],
    status: 'Full Stack',
    statusColor: '',
    span: '',
    accentVar: '--accent: hsl(180,70%,45%)',
    accentHsl: '180,70%,45%',
  },
  {
    id: 'axto',
    num: '05',
    name: 'Axto',
    tagline: 'High-performance web architecture',
    description: 'Engineered for speed, reliability, and elegance. A demonstration project with meticulous attention to DX and performance at every level.',
    url: null,
    tags: ['Web App', 'Architecture'],
    status: 'Demo',
    statusColor: '',
    span: '',
    accentVar: '--accent: hsl(50,90%,55%)',
    accentHsl: '50,90%,55%',
  },
];

const skills = [
  { name: 'Rust', level: 'Advanced', category: 'lang' },
  { name: 'TypeScript', level: 'Advanced', category: 'lang' },
  { name: 'Python', level: 'Proficient', category: 'lang' },
  { name: 'C / C++', level: 'Advanced', category: 'lang' },
  { name: 'React', level: 'Advanced', category: 'frontend' },
  { name: 'Next.js', level: 'Proficient', category: 'frontend' },
  { name: 'Astro', level: 'Proficient', category: 'frontend' },
  { name: 'Node.js', level: 'Proficient', category: 'backend' },
  { name: 'Supabase / PostgreSQL', level: 'Proficient', category: 'data' },
  { name: 'Systems Programming', level: 'Advanced', category: 'systems' },
  { name: 'Compiler Design', level: 'Intermediate', category: 'systems' },
  { name: 'Concurrency / Multithreading', level: 'Advanced', category: 'systems' },
];

const levelColor: Record<string, string> = {
  Advanced: 'hsl(24,100%,60%)',
  Proficient: 'hsl(0,0%,50%)',
  Intermediate: 'hsl(0,0%,35%)',
};

const marqueeItems = ['Rust', 'TypeScript', 'Python', 'React', 'Next.js', 'C++', 'Astro', 'Supabase', 'Node.js', 'x86-64', 'PostgreSQL', 'WebSockets', 'HTTP', 'HE-Arc'];
---

<Layout
  title="Yanis Amani — Software Developer & CS Student"
  description="Yanis Amani — CS student at HE-Arc Neuchâtel and software developer. I build blazing-fast web applications and systems software in Rust, TypeScript & C++. Available for internships and freelance work."
>

<!-- ═══════════════════════ HERO ═══════════════════════ -->
<header id="hero" class="relative min-h-screen flex flex-col justify-end pb-20 pt-28 md:pt-0 overflow-hidden">

  <!-- Huge background number -->
  <div aria-hidden="true"
    class="absolute -right-8 bottom-0 select-none pointer-events-none leading-none font-black text-[hsl(0,0%,7%)]"
    style="font-size: clamp(14rem, 35vw, 32rem); letter-spacing: -0.06em; line-height: 0.8;">
    01
  </div>

  <!-- Orange glow sphere -->
  <div aria-hidden="true"
    class="absolute top-24 right-[12%] w-64 h-64 md:w-96 md:h-96 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, hsl(24,100%,60%) 0%, transparent 70%); opacity: 0.06; filter: blur(1px);">
  </div>

  <!-- Grid lines decoration -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(hsl(0,0%,12%) 1px, transparent 1px), linear-gradient(90deg, hsl(0,0%,12%) 1px, transparent 1px); background-size: 80px 80px; opacity: 0.25;"></div>

  <div class="max-w-7xl mx-auto w-full px-6 md:px-12 relative z-10">

    <!-- Status pill -->
    <div class="mb-10 flex items-center gap-4" data-animate>
      <div class="flex items-center gap-2 border border-[hsl(0,0%,18%)] rounded-sm px-3 py-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-[hsl(142,70%,55%)] animate-pulse" aria-hidden="true"></span>
        <span class="mono-label">available for internships & freelance</span>
      </div>
      <span class="rule flex-1 hidden sm:block"></span>
      <span class="mono-label hidden sm:block">neuchâtel · switzerland</span>
    </div>

    <!-- Main heading — two-line asymmetric layout -->
    <div data-animate data-delay="1">
      <h1>
        <span class="display-xl block text-[hsl(0,0%,97%)] leading-none">
          YANIS
        </span>
        <div class="flex flex-col sm:flex-row sm:items-end gap-4 sm:gap-8 mt-2">
          <span class="display-xl block text-[hsl(0,0%,97%)] leading-none">
            AMANI<span class="text-[hsl(24,100%,60%)]">.</span>
          </span>
          <!-- Vertical descriptor -->
          <div class="sm:mb-3 flex flex-col gap-1.5 sm:pb-2">
            <span class="mono-label">Software Developer</span>
            <span class="mono-label">BSc CS @ HE-Arc</span>
            <span class="mono-label">Rust · TypeScript · C++</span>
          </div>
        </div>
      </h1>
    </div>

    <!-- Subtitle + CTA row -->
    <div class="mt-12 flex flex-col sm:flex-row items-start sm:items-end justify-between gap-8" data-animate data-delay="2">
      <p class="text-[hsl(0,0%,45%)] max-w-md leading-relaxed text-base">
        I build things that are fast by design — from real-time frontends that never flicker
        to systems-level software written without training wheels.
      </p>
      <div class="flex gap-3 flex-shrink-0">
        <a href="#projects" class="btn btn-orange text-sm" title="View my projects">
          see the work
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>
        <a href="mailto:yanis.amani@icloud.com" class="btn btn-ghost text-sm">
          say hello →
        </a>
      </div>
    </div>

    <!-- Stats strip -->
    <div class="mt-16 pt-8 border-t border-[hsl(0,0%,14%)] grid grid-cols-3 gap-4" data-animate data-delay="3">
      {[
        { n: '5+', l: 'Projects' },
        { n: '3',  l: 'Core Languages' },
        { n: '2+', l: 'Years Building' },
      ].map(s => (
        <div>
          <div class="text-3xl md:text-4xl font-black text-white mb-1 tabular-nums">{s.n}</div>
          <div class="mono-label">{s.l}</div>
        </div>
      ))}
    </div>
  </div>
</header>


<!-- ═══════════════════════ MARQUEE ═══════════════════════ -->
<div aria-label="Technologies" class="overflow-hidden border-y border-[hsl(0,0%,12%)] py-4 bg-[hsl(0,0%,7%)]">
  <div class="flex gap-10 whitespace-nowrap" style="animation: marquee 30s linear infinite;">
    {[...marqueeItems, ...marqueeItems].map(item => (
      <span class="inline-flex items-center gap-4 font-mono text-[hsl(0,0%,30%)] text-xs font-bold uppercase tracking-widest">
        {item} <span class="text-[hsl(24,100%,50%)] text-xs" aria-hidden="true">◆</span>
      </span>
    ))}
  </div>
</div>


<!-- ═══════════════════════ PROJECTS ═══════════════════════ -->
<section id="projects" aria-labelledby="projects-heading" class="py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <!-- Section header -->
    <div class="flex items-end justify-between mb-16" data-animate>
      <div>
        <span class="section-num">§ 01 / projects</span>
        <h2 id="projects-heading" class="display-md text-white">
          Selected<br/><span class="text-[hsl(0,0%,35%)]">Work</span>
        </h2>
      </div>
      <a href="https://github.com/DevYatsu" target="_blank" rel="noopener noreferrer"
        class="hidden sm:flex btn btn-ghost text-xs" aria-label="See all projects on GitHub">
        all on github ↗
      </a>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {projects.map((p, i) => (
        <article id={`project-${p.id}`}
          class={`bento group ${p.span}`}
          style={p.accentVar}
          data-animate
          data-delay={String(i % 3 + 1)}
          aria-label={`Project: ${p.name}`}>

          <!-- Accent glow on hover -->
          <div class="absolute inset-0 rounded-[inherit] opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
            style={`background: radial-gradient(ellipse 60% 50% at 30% 50%, hsla(${p.accentHsl}, 0.06) 0%, transparent 100%);`}
            aria-hidden="true">
          </div>

          <!-- Top row -->
          <div class="flex items-start justify-between mb-8 relative z-10">
            <span class="counter">{p.num}</span>
            <span class={`chip ${p.statusColor}`}>{p.status}</span>
          </div>

          <!-- Name -->
          <h3 class="text-xl md:text-2xl font-black text-white mb-2 leading-tight relative z-10
                      group-hover:text-[var(--accent)] transition-colors duration-300">
            {p.name}
          </h3>
          <p class="text-xs font-mono text-[hsl(0,0%,38%)] mb-4 relative z-10">{p.tagline}</p>
          <p class="text-sm text-[hsl(0,0%,48%)] leading-relaxed flex-grow mb-6 relative z-10">{p.description}</p>

          <!-- Bottom row -->
          <div class="flex flex-wrap items-center justify-between gap-3 mt-auto relative z-10">
            <div class="flex flex-wrap gap-1.5">
              {p.tags.map(t => <span class="chip">{t}</span>)}
            </div>
            {p.url
              ? <a href={p.url} target="_blank" rel="noopener noreferrer"
                  aria-label={`Visit ${p.name} live`}
                  class="text-xs font-mono text-[hsl(0,0%,40%)] hover:text-[var(--accent)] transition-colors flex items-center gap-1">
                  visit ↗
                </a>
              : <a href="https://github.com/DevYatsu" target="_blank" rel="noopener noreferrer"
                  aria-label={`View source of ${p.name}`}
                  class="text-xs font-mono text-[hsl(0,0%,40%)] hover:text-white transition-colors flex items-center gap-1">
                  src ↗
                </a>
            }
          </div>
        </article>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════ SKILLS ═══════════════════════ -->
<section id="skills" aria-labelledby="skills-heading" class="py-24 md:py-32 border-t border-[hsl(0,0%,12%)]">
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

      <!-- Left: heading + terminal -->
      <div>
        <div data-animate>
          <span class="section-num">§ 02 / skills</span>
          <h2 id="skills-heading" class="display-md text-white mb-6">
            Tools I<br/><span class="text-[hsl(0,0%,35%)]">Actually Use</span>
          </h2>
          <p class="text-[hsl(0,0%,42%)] text-sm leading-relaxed max-w-sm mb-10">
            Not a skills spider chart. Just the real stuff I reach for when building something that needs to be fast, correct, and maintainable.
          </p>
        </div>

        <!-- Terminal block -->
        <div class="terminal" data-animate data-delay="2">
          <div class="flex items-center gap-1.5 mb-4 pb-3 border-b border-[hsl(0,0%,14%)]">
            <span class="w-2.5 h-2.5 rounded-full bg-[hsl(0,80%,55%)]" aria-hidden="true"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[hsl(40,90%,55%)]" aria-hidden="true"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[hsl(142,60%,50%)]" aria-hidden="true"></span>
            <span class="ml-3 t-gray">~/yanis-amani</span>
          </div>
          <div>
            <p><span class="t-green">❯</span> <span class="t-white">whoami</span></p>
            <p class="t-gray ml-4">student @ HE-Arc, Neuchâtel</p>
            <p class="t-gray ml-4">BSc Computer Science — in progress</p>
            <br/>
            <p><span class="t-green">❯</span> <span class="t-white">cat interests.txt</span></p>
            <p class="ml-4"><span class="t-orange">systems programming</span>, <span class="t-blue">web perf</span>,</p>
            <p class="ml-4"><span class="t-orange">compiler design</span>, <span class="t-blue">real-time UX</span></p>
            <br/>
            <p><span class="t-green">❯</span> <span class="t-white">echo $STATUS</span></p>
            <p class="ml-4 t-orange">open to opportunities<span class="t-white blink">_</span></p>
          </div>
        </div>
      </div>

      <!-- Right: skill rows -->
      <div data-animate data-delay="1">
        <div class="space-y-0">
          {skills.map((s, i) => (
            <div class="skill-row" role="listitem" aria-label={`${s.name}: ${s.level}`}>
              <div class="flex items-center gap-3">
                <span class="mono-label w-4 text-center">{String(i + 1).padStart(2, '0')}</span>
                <span class="text-[hsl(0,0%,80%)] font-semibold text-sm">{s.name}</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="font-mono text-xs" style={`color: ${levelColor[s.level]}`}>{s.level}</span>
                <!-- Level bar -->
                <div class="w-16 h-px bg-[hsl(0,0%,18%)] relative hidden sm:block" aria-hidden="true">
                  <div class="absolute top-0 left-0 h-full rounded-full transition-all duration-500"
                    style={`width: ${s.level === 'Advanced' ? '100%' : s.level === 'Proficient' ? '65%' : '40%'}; background: ${levelColor[s.level]};`}>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ═══════════════════════ ABOUT ═══════════════════════ -->
<section id="about" aria-labelledby="about-heading" class="py-24 md:py-32 border-t border-[hsl(0,0%,12%)] overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-12">

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-0">

      <!-- Large quote / manifesto -->
      <div class="lg:col-span-2 lg:pr-16 border-r-0 lg:border-r border-[hsl(0,0%,12%)]" data-animate>
        <span class="section-num">§ 03 / about</span>
        <h2 id="about-heading" class="display-md text-white mb-8">
          I believe software<br/>
          should be <span class="text-[hsl(24,100%,60%)]">fast</span>,<br/>
          <span class="text-[hsl(0,0%,35%)]">correct</span>, and<br/>
          <span class="text-[hsl(0,0%,35%)]">a pleasure to use.</span>
        </h2>
        <p class="text-[hsl(0,0%,42%)] text-sm leading-relaxed max-w-lg">
          I'm Yanis — a CS student at HE-Arc Neuchâtel fascinated by the full spectrum of software: from designing pixel-perfect, zero-latency interfaces to hand-writing JIT compilers that execute machine code directly.
          I don't stop at "it works."
        </p>
      </div>

      <!-- Cards column -->
      <div class="lg:pl-12 flex flex-col gap-4">
        <div class="bento !py-5 !px-6" data-animate data-delay="1">
          <p class="mono-label mb-2">currently</p>
          <p class="text-white font-semibold text-sm">BSc Computer Science</p>
          <p class="text-[hsl(0,0%,38%)] text-xs mt-0.5">HE-Arc · Neuchâtel · Switzerland</p>
        </div>
        <div class="bento !py-5 !px-6" data-animate data-delay="2">
          <p class="mono-label mb-2">GitHub</p>
          <a href="https://github.com/DevYatsu" target="_blank" rel="noopener noreferrer"
            class="text-white font-semibold text-sm hover:text-[hsl(24,100%,60%)] transition-colors">
            @DevYatsu ↗
          </a>
        </div>
        <div class="bento !py-5 !px-6" data-animate data-delay="3">
          <p class="mono-label mb-2">languages spoken</p>
          <p class="text-white font-semibold text-sm">French · English</p>
        </div>
        <div class="bento !py-5 !px-6" data-animate data-delay="4">
          <p class="mono-label mb-2">interests</p>
          <div class="flex flex-wrap gap-1.5 mt-1">
            {['Compilers', 'Web Perf', 'Systems', 'Open Source', 'UI/UX'].map(t => (
              <span class="chip">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════ CONTACT ═══════════════════════ -->
<section id="contact" aria-labelledby="contact-heading" class="py-24 md:py-32 border-t border-[hsl(0,0%,12%)] relative overflow-hidden">

  <!-- Big background text -->
  <div aria-hidden="true"
    class="absolute inset-0 flex items-center justify-center select-none pointer-events-none overflow-hidden">
    <span class="font-black text-[hsl(0,0%,7%)] whitespace-nowrap"
      style="font-size: clamp(6rem, 18vw, 16rem); letter-spacing: -0.05em; line-height: 1;">
      LET'S TALK
    </span>
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <div class="max-w-2xl" data-animate>
      <span class="section-num">§ 04 / contact</span>
      <h2 id="contact-heading" class="display-md text-white mb-6">
        Got a project<br/>in mind?
      </h2>
      <p class="text-[hsl(0,0%,42%)] text-sm leading-relaxed mb-10 max-w-md">
        Whether you need a performant web application, low-level systems work, or just want to talk tech — my inbox is open.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="mailto:yanis.amani@icloud.com" id="contact-email-cta"
          class="btn btn-orange text-sm glow-pulse"
          title="Send Yanis Amani an email" aria-label="Email Yanis Amani">
          yanis.amani@icloud.com
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <a href="https://linkedin.com/in/yanis-amani" target="_blank" rel="noopener noreferrer"
          class="btn btn-ghost text-sm"
          title="Connect on LinkedIn" aria-label="Yanis Amani on LinkedIn">
          LinkedIn ↗
        </a>
      </div>

      <!-- Social row -->
      <div class="mt-16 pt-8 border-t border-[hsl(0,0%,12%)] flex items-center gap-8 flex-wrap">
        <a href="https://github.com/DevYatsu" target="_blank" rel="noopener noreferrer"
          class="mono-label hover:text-[hsl(0,0%,70%)] transition-colors">
          github.com/DevYatsu
        </a>
        <span class="rule flex-1 hidden sm:block"></span>
        <span class="mono-label">NeuchâtelI, CH</span>
      </div>
    </div>
  </div>
</section>

</Layout>
