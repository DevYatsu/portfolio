</Layout>

<script is:inline data-astro-rerun>
	(function() {
		var stored = localStorage.getItem('lang');
		var browserLang = (navigator.language || navigator.userLanguage || '').substring(0, 2);
		var lang = stored || (browserLang === 'fr' ? 'fr' : 'en');
		if (lang !== 'en') {
			document.documentElement.setAttribute('data-lang', lang);
			document.documentElement.lang = lang;
		}
	})();

	window.__setLanguage = function(lang) {
		document.documentElement.setAttribute('data-lang', lang);
		document.documentElement.lang = lang;
		localStorage.setItem('lang', lang);
		// Reset skill filter — activate "All" in the visible language section
		document.querySelectorAll('.skill-tag').forEach(function(el) { el.style.display = ''; });
		document.querySelectorAll('.skills-filter-btn').forEach(function(b) { b.classList.remove('active'); });
		var visibleAll = document.querySelector('section[data-lang="' + lang + '"] .skills-filter-btn[data-filter="all"]');
		if (visibleAll) visibleAll.classList.add('active');
		// Force .visible on data-animate elements that are in the now-visible section
		if (window.__revealAnimations) window.__revealAnimations();
		// Re-apply filter to the visible section
		if (window.__filterSkills) window.__filterSkills();
		// Update language toggle button text
		var el = document.getElementById('lang-label');
		if (el) el.textContent = lang === 'fr' ? 'EN' : 'FR';
	};
</script>

<script>
	// Skill filter interaction — global function so __setLanguage can call it
	window.__filterSkills = function() {
		const active = document.querySelector('.skills-filter-btn.active');
		const tags = document.querySelectorAll('.skill-tag');
		const filterVal = active ? active.dataset.filter : 'all';
		tags.forEach(tag => {
			// Only toggle tags in the visible language container.
			// Check the section's offsetParent (null when section has display:none)
			// rather than the tag's — tags hidden by a previous filter also have
			// offsetParent === null, which would make them unfixable.
			const section = tag.closest('[data-lang]');
			if (!section || section.offsetParent === null) return;
			tag.style.display = (filterVal === 'all' || tag.dataset.category === filterVal) ? '' : 'none';
		});
	};

	// Force .visible on data-animate elements that are currently visible (skips IntersectionObserver delay)
	window.__revealAnimations = function() {
		document.querySelectorAll('[data-animate]').forEach(el => {
			if (el.offsetParent !== null) el.classList.add('visible');
		});
	};

	document.addEventListener('astro:page-load', () => {
		document.querySelectorAll('.skills-filter-btn').forEach(btn => {
			btn.addEventListener('click', () => {
				document.querySelectorAll('.skills-filter-btn').forEach(b => b.classList.remove('active'));
				btn.classList.add('active');
				window.__filterSkills();
			});
		});
	});
</script>

<style>
	/* ── Language toggle ── */
	[data-lang] { display: none; }
	[data-lang="en"] { display: block; }
	html[data-lang="fr"] [data-lang="en"] { display: none; }
	html[data-lang="fr"] [data-lang="fr"] { display: block; }

	/* ── Hero ── */
	.hero {
		min-height: 85vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding-top: 3.5rem;
	}
	.hero-tag {
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--accent);
		font-weight: 500;
		margin-bottom: 1.25rem;
		display: block;
	}
	.hero .accent-rule { margin-bottom: 2rem; }
	.hero-title {
		font-size: clamp(2.5rem, 8vw, 5rem);
		letter-spacing: -0.03em;
		line-height: 0.92;
		margin-bottom: 1.5rem;
	}
	.hero-accent { font-style: italic; color: var(--accent); }
	.hero-role {
		font-size: 1rem;
		color: var(--text-muted);
		line-height: 1.6;
		max-width: 32rem;
		margin-bottom: 2.5rem;
	}
	@media (min-width: 768px) { .hero-role { font-size: 1.125rem; } }
	.hero-actions { display: flex; gap: 1rem; align-items: center; }

	/* ── Info Bar ── */
	.info-bar {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: var(--border);
		border-top: 1px solid var(--border);
	}

	/* ── Projects ── */
	.projects-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.project-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1rem;
	}
	.project-detail-link { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text); opacity: 0.35; font-weight: 400; transition: opacity 0.2s; }
	.project-card:hover .project-detail-link { opacity: 0.6; }
	.project-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
	}
	.project-link {
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--accent);
		font-weight: 500;
		text-decoration: none;
		margin-left: auto;
		transition: color 0.2s;
		white-space: nowrap;
	}
	.project-link:hover { color: var(--accent-hover); }

	/* ── Static Websites ── */
	.static-header {
		border-top: 1px solid var(--border);
		padding-top: 2.5rem;
		margin-bottom: 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.static-label {
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--text-dim);
	}
	.static-count {
		font-size: 0.65rem;
		color: var(--text-dim);
	}
	.static-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1px;
		background: var(--border);
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
	}
	@media (min-width: 640px) {
		.static-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (min-width: 1024px) {
		.static-grid { grid-template-columns: repeat(3, 1fr); }
	}
	.static-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }

	/* ── Skills Filter ── */
	.skills-filter {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}
	.skills-filter-btn {
		font-family: var(--font-sans);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding: 0.4rem 0.85rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: transparent;
		color: var(--text-muted);
		cursor: pointer;
		transition: all 0.2s;
	}
	.skills-filter-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.skills-filter-btn.active {
		background: var(--accent);
		color: white;
		border-color: var(--accent);
	}

	/* ── Skills ── */
	.skills-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.skill-tag {
		font-size: 0.8125rem;
		padding: 0.35rem 0.85rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		color: var(--text-muted);
		background: var(--surface);
		transition: all 0.2s;
		cursor: default;
		line-height: 1.4;
	}
	.skill-tag:hover {
		border-color: var(--accent);
		color: var(--accent);
		background: var(--accent-light);
	}

	/* ── About ── */
	.about-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		align-items: start;
	}
	@media (min-width: 1024px) {
		.about-grid {
			grid-template-columns: 2fr 1fr;
		}
	}
	.about-text {
		font-size: 1.125rem;
		color: var(--text-muted);
		line-height: 1.7;
	}

	/* ── Contact ── */
	.contact-grid {
		display: grid;
