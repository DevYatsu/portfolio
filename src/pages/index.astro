---
import Layout from "../layouts/Layout.astro";
import { projects, staticSites, skills } from "../data/portfolio";
---

<Layout title="Yanis Amani // CS Student | Étudiant en Informatique">
	<section data-lang="en">
		<!-- ═══ HERO ═══ -->
		<section class="hero" data-animate>
			<div class="container hero-inner">
				<span class="hero-tag">Systems · Web · Reliability</span>
				<div class="accent-rule"></div>
				<h1 class="hero-title">
					Building<br/>
					<span class="hero-accent">Reliability.</span>
				</h1>
				<p class="hero-role">I'm a CS student who likes building stuff that doesn't fall over. Rust, TypeScript, systems programming. The fun kind of problems.</p>
				<div class="hero-actions">
					<a href="#projects" class="btn-primary">View Projects →</a>
					<a href="#contact" class="btn-ghost">Get in Touch</a>
				</div>
			</div>
		</section>

		<!-- ═══ INFO BAR ═══ -->
		<div class="container">
			<div class="info-bar">
				<div class="info-item" style="background: var(--bg);">
					<div class="label">Role</div>
					<div class="value">CS Student</div>
				</div>
				<div class="info-item" style="background: var(--bg);">
					<div class="label">Focus</div>
					<div class="value">Quality Code</div>
				</div>
				<div class="info-item" style="background: var(--bg);">
					<div class="label">Education</div>
					<div class="value">BSc Computer Science</div>
				</div>
			</div>
		</div>

		<!-- ═══ PROJECTS ═══ -->
		<section id="projects" class="section-pad">
			<div class="container">
				<div class="section-header" data-animate>
					<h2>Projects</h2>
					<p class="sub">Stuff I actually built. Side projects, open-source tools, the kind of things you work on at 1am because they're fun.</p>
				</div>

				<div class="projects-list">
					{projects.map((p) => (
						<a href={`/projects/${p.id}`} class="project-card" data-animate aria-label={p.name}>
							<div class="project-top">
								<span class="cat">{p.category.en}</span>
								<span class="project-detail-link">View details</span>
							</div>
							<h3 class="name">{p.name}</h3>
							<p class="desc">{p.description.en}</p>
							<div class="project-meta" onclick="event.stopPropagation()">
								{p.tags.map((tag) => (
									<a href={tag.url} target="_blank" rel="noopener noreferrer" class="tech-tag" onclick="event.stopPropagation()">{tag.name}</a>
								))}
								{p.link.url ? (
									<a href={p.link.url} target="_blank" rel="noopener noreferrer" class="project-link" onclick="event.stopPropagation()">
										{p.link.label}
									</a>
								) : (
									<span class="project-link" style="opacity: 0.4; cursor: default;">{p.link.label}</span>
								)}
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		<!-- ═══ STATIC WEBSITES ═══ -->
		<section class="container" style="padding-bottom: 4rem;">
			<div class="static-header">
				<span class="static-label">Also · Static Websites</span>
				<span class="static-count">{staticSites.length} projects</span>
			</div>
			<div class="static-grid">
				{staticSites.map((site, i) => (
					<a href={site.url} target="_blank" rel="noopener noreferrer" class="static-card">
						<div class="num">0{i + 1}</div>
						<h3 class="name">{site.name}</h3>
						<p class="desc">{site.description.en}</p>
						<div class="static-tags">
							{site.tags.map((tag) => (
								<span class="mini-tag">{tag}</span>
							))}
						</div>
						<span class="static-hover-text">click to access</span>
					</a>
				))}
			</div>
		</section>

		<!-- ═══ SKILLS ═══ -->
		<section id="skills" class="section-pad" style="border-top: 1px solid var(--border);">
			<div class="container">
				<div class="section-header" data-animate>
					<h2>My Tools</h2>
					<p class="sub">Languages and frameworks I actually reach for.</p>
				</div>

				<div class="skills-filter" data-animate>
					<button class="skills-filter-btn active" data-filter="all">All</button>
					<button class="skills-filter-btn" data-filter="lang">Languages</button>
					<button class="skills-filter-btn" data-filter="frontend">Frontend</button>
					<button class="skills-filter-btn" data-filter="backend">Backend</button>
					<button class="skills-filter-btn" data-filter="systems">Systems</button>
				</div>

				<div class="skills-tags" data-animate>
					{skills.map((s) => (
						<span class="skill-tag" data-category={s.category}>{s.name}</span>
					))}
				</div>
			</div>
		</section>

		<!-- ═══ ABOUT ═══ -->
		<section id="about" class="section-pad" style="border-top: 1px solid var(--border);">
			<div class="container">
				<div class="section-header" data-animate>
					<h2>My Approach</h2>
					<p class="sub">I try to write code that doesn't embarrass me six months later.</p>
				</div>

				<div class="about-grid" data-animate>
					<p class="about-text">I care about the boring stuff. Good error handling. Clean interfaces. Not shipping yet another npm package that could've been a file. I've broken enough things in production to know that "it works on my machine" is not a testing strategy. These days I'd rather go slow and get it right.</p>
					<div class="values-box">
						<div class="v-label">Core Values</div>
						<div class="v-item">Reliability</div>
						<div class="v-item">Performance</div>
						<div class="v-item">Security</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ CONTACT ═══ -->
		<section id="contact" class="section-pad" style="border-top: 1px solid var(--border); margin-bottom: 4rem;">
			<div class="container">
				<div class="section-header" data-animate>
					<h2>Get in Touch</h2>
					<p class="sub">Got a project, an idea, or just want to chat? I'm around.</p>
				</div>

				<div class="contact-grid" data-animate>
					<div>
						<p class="contact-label">Email</p>
						<a href="mailto:yanis.amani@icloud.com" class="contact-email">
							yanis.amani@icloud.com
						</a>
						<p class="contact-label" style="margin-top: 2rem;">Social</p>
						<div class="contact-socials">
							<a href="https://linkedin.com/in/yanis-amani" target="_blank" class="social-link">LinkedIn ↗</a>
							<a href="https://github.com/DevYatsu" target="_blank" class="social-link">GitHub ↗</a>
						</div>
					</div>
					<div class="contact-hello">
						<p class="contact-label">Send a message</p>
						<a href="mailto:yanis.amani@icloud.com" class="big-hello">hello@ →</a>
					</div>
				</div>
			</div>
		</section>
	</section>

