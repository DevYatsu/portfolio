---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Impressum & Privacy Policy // Yanis Amani"
  description="Legal notice and privacy policy for Yanis Amani's portfolio."
  lang="en"
>
  <section class="py-24 px-6 md:px-12 max-w-4xl mx-auto">
    <!-- Navigation -->
    <a href="/" class="nav-link inline-flex items-center gap-2 mb-16" data-animate>
      BACK TO HOME ↗
    </a>

    <!-- Header -->
    <div class="mb-24" data-animate>
      <span class="tech-label mb-6 inline-block">LEGAL INFO</span>
      <h1 class="display-md uppercase font-black mb-6 leading-none">
        IMPRESSUM &<br/>
        <span class="text-primary italic">PRIVACY POLICY</span>
      </h1>
      <p class="font-mono text-[0.6rem] text-text-dim uppercase tracking-widest">
        LAST UPDATE // MARCH 2026
      </p>
    </div>

    <div class="space-y-24">
      <!-- Section 1: Publisher -->
      <div class="structural-border p-12 bg-bg-surface" data-animate>
        <div class="flex justify-between items-start mb-12">
          <span class="tech-label">SECTION 01 // PUBLISHER</span>
          <div class="w-12 h-px bg-border-subtle"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="space-y-6">
            <h2 class="text-2xl font-black uppercase tracking-tight">YANIS AMANI</h2>
            <p class="font-mono text-[0.7rem] text-text-muted leading-relaxed uppercase">
              Computer Science Student @ HE-Arc<br/>
              Neuchâtel, Switzerland
            </p>
          </div>
          <div class="space-y-6">
            <span class="tech-label block mb-4 w-fit">CONTACT DIRECT</span>
            <a href="mailto:yanis.amani@icloud.com" class="text-xl font-black text-primary hover:text-primary-dark transition-colors break-all">
              YANIS.AMANI@ICLOUD.COM
            </a>
          </div>
        </div>
      </div>

      <!-- Section 2: Privacy -->
      <div class="structural-border p-12 bg-bg-surface" data-animate>
        <div class="flex justify-between items-start mb-12">
          <span class="tech-label">SECTION 02 // DATA PRIVACY</span>
          <div class="w-12 h-px bg-border-subtle"></div>
        </div>
        <div class="space-y-8">
          <h2 class="text-2xl font-black uppercase tracking-tight">PRIVACY FIRST POLICY</h2>
          <p class="text-text-muted leading-relaxed">
            This website is built with privacy in mind. No tracking cookies are used, and no third-party analytics are active. 
          </p>
          <div class="p-6 border border-primary/20 bg-primary/5">
            <h3 class="font-bold uppercase text-xs mb-4 text-primary">YOUR RIGHTS</h3>
            <p class="text-sm text-text-muted font-mono leading-relaxed uppercase">
              You have the right to access, change, or delete any personal information sent through official channels.
            </p>
          </div>
        </div>
      </div>

      <!-- Section 3: Hosting -->
      <div class="structural-border p-12 bg-bg-surface" data-animate>
        <div class="flex justify-between items-start mb-12">
          <span class="tech-label">SECTION 03 // HOSTING</span>
          <div class="w-12 h-px bg-border-subtle"></div>
        </div>
        <div class="space-y-4">
          <h2 class="text-xl font-black uppercase">NETLIFY INC</h2>
          <p class="font-mono text-[0.7rem] text-text-muted uppercase">
            44 MONTGOMERY ST, SAN FRANCISCO, CA 94104
          </p>
        </div>
      </div>
    </div>

    <!-- Footer link -->
    <div class="mt-32 pt-12 border-t border-border-subtle text-center">
      <a href="/" class="btn-arch inline-flex">
        BACK TO HOME
      </a>
    </div>
  </section>
</Layout>
