---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 // Page Not Found — Yanis Amani"
  description="The page you requested was not found. Return to Yanis Amani's portfolio."
>
  <section class="error-page" data-animate>
    <div class="error-card">
      <span class="error-code">404</span>
      <h1 class="error-title">
        Page not<br/>
        <span class="error-accent">found.</span>
      </h1>
      <p class="error-desc">
        Either the link is broken or I moved things around. Sorry about that.
        Head back to the homepage and you'll find what you need.
      </p>
      <a href="/" class="btn-primary">Back to Home</a>
    </div>
  </section>
</Layout>

<style>
.error-page {
  min-height: 80vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: var(--space-2xl) var(--space-md);
  text-align: center;
}

.error-card {
  max-width: 28rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-lg);
}

.error-code {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-muted);
  letter-spacing: 0.1em;
}

.error-title {
  font-size: var(--text-display);
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 0.92;
}

.error-accent {
  color: var(--color-accent);
  font-style: normal;
}

.error-desc {
  font-size: var(--text-base);
  color: var(--color-muted);
  line-height: 1.6;
  max-width: 24rem;
  font-family: var(--font-body);
}
</style>
