---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Segmentation Fault"
  description="File not found on Yanis Amani's portfolio."
  lang="en"
>
  <section class="min-h-[90vh] flex flex-col justify-center py-32 md:py-48 relative overflow-hidden">
    <!-- Background Blur -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-160 h-160 bg-red-500/5 blur-[120px] rounded-full"></div>
    </div>

    <div class="max-w-3xl mx-auto px-6 w-full relative z-10 text-center">
      <div data-animate>
        <span class="section-tag mb-8 bg-red-500/10! border-red-500/20! text-red-400!">ERROR_CODE: 0x00000404</span>
        <h1 class="display-lg text-white mb-12 tracking-tighter leading-[0.8]">
          SEGMENTATION <br/>
          <span class="text-red-500 italic">FAULT.</span>
        </h1>

        <div class="terminal-modern text-left mb-16 max-w-xl mx-auto border-red-500/20! bg-red-950/5!">
          <div class="flex items-center gap-2 mb-8 border-b border-red-500/10 pb-4">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/20 border border-red-500/50"></div>
              <div class="w-3 h-3 rounded-full bg-red-500/10 border border-white/5"></div>
              <div class="w-3 h-3 rounded-full bg-red-500/10 border border-white/5"></div>
            </div>
            <span class="ml-4 text-red-400/60 text-xs font-mono">kernel@system: ~</span>
          </div>
          <div class="font-mono text-sm leading-relaxed space-y-3">
            <p><span class="text-red-500 font-bold">[PANIC]</span> Unhandled exception at 0x00000404</p>
            <p class="text-text-muted">Requested memory address is not mapped to current process space.</p>
            <div class="pt-4 border-t border-red-500/10">
              <p class="flex gap-3"><span class="text-primary font-bold">❯</span> <span>reboot --target /</span></p>
              <p class="ml-6 text-primary font-bold">Safe mode initiated<span class="animate-pulse">_</span></p>
            </div>
          </div>
        </div>

        <a href="/" class="btn btn-primary px-10! py-5! text-lg group">
          <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
          Return to Root
        </a>
      </div>
    </div>
  </section>
</Layout>
