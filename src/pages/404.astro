---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 // Page Not Found"
  description="The page you requested was not found on Yanis Amani's portfolio."
  lang="en"
>
  <section class="min-h-[80vh] flex flex-col justify-center items-center px-6 py-24 max-w-7xl mx-auto">
    <div class="text-center space-y-12" data-animate>
      <div class="inline-flex items-center gap-4">
        <span class="tech-label bg-red-500 text-white border-red-600">ERROR 404</span>
        <div class="h-px w-12 bg-red-500/30"></div>
        <span class="font-mono text-[0.6rem] text-red-500 uppercase tracking-widest font-black">ACCESS DENIED</span>
      </div>

      <h1 class="display-title leading-[0.8] tracking-tighter">
        PAGE NOT<br/>
        <span class="text-primary italic">FOUND.</span>
      </h1>

      <div class="max-w-xl mx-auto structural-border p-8 bg-bg-surface text-left">
        <div class="flex justify-between items-start mb-6">
          <span class="tech-label">ERROR INFO</span>
          <span class="text-red-500 font-mono text-[0.6rem] animate-pulse">SYSTEM ALERT</span>
        </div>
        <p class="font-mono text-[0.7rem] text-text-muted leading-relaxed mb-8">
          The link you followed may be broken, or the page may have been removed. 
          Please return to the main page to continue browsing.
        </p>
        <div class="flex flex-col gap-4">
          <div class="flex justify-between border-b border-border-subtle pb-2 font-mono text-[0.6rem]">
            <span class="text-text-dim">ERROR TYPE</span>
            <span class="text-red-500 font-bold">PAGE NOT FOUND</span>
          </div>
          <div class="flex justify-between border-b border-border-subtle pb-2 font-mono text-[0.6rem]">
            <span class="text-text-dim">LOCATION</span>
            <span class="text-text-main font-bold">/UNKNOWN PATH</span>
          </div>
        </div>
      </div>

      <a href="/" class="btn-arch inline-flex mx-auto">
        BACK TO HOME
      </a>
    </div>
  </section>
</Layout>
