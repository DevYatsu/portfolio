---
import Layout from "../layouts/Layout.astro";
import { projects, staticSites, skills } from "../data/portfolio";

const lang = "fr";
const t = {
	heroTag: "Systèmes · Web · Fiabilité",
	heroName: "Construire la",
	heroNameAccent: "Fiabilité.",
	heroRole: "Étudiant en informatique, j'aime construire des trucs qui tiennent la route. Rust, TypeScript, programmation système. Le genre de problèmes qui sont marrants.",
	ctaProjects: "Voir les projets →",
	ctaContact: "Me contacter",
	infoRole: "Rôle", infoRoleVal: "Étudiant",
	infoFocus: "Focus", infoFocusVal: "Code de qualité",
	infoEdu: "Formation", infoEduVal: "BSc Informatique",
	projectsTitle: "Projets",
	projectsSub: "Des trucs que j'ai vraiment construits. Projets perso, outils open-source, le genre de code que tu écris à 1h du matin parce que c'est trop fun.",
	staticTitle: "Aussi · Sites statiques",
	skillsTitle: "Mes outils",
	skillsSub: "Langages et frameworks que j'utilise vraiment.",
	aboutTitle: "Mon approche",
	aboutSub: "J'essaie d'écrire du code qui ne me fait pas honte six mois après.",
	aboutText: "Je me soucie des trucs ennuyeux. La gestion d'erreurs propre. Des interfaces claires. Ne pas balancer un énième package npm qui aurait pu être un fichier. J'ai assez cassé de choses en production pour savoir que \"ça marche sur ma machine\" n'est pas une stratégie de test. Maintenant je préfère aller lentement mais bien faire les choses.",
	valuesTitle: "Valeurs",
	values: ["Fiabilité", "Performance", "Sécurité"],
	contactTitle: "Me contacter",
	contactSub: "Un projet, une idée, ou juste envie de parler ? Je suis là.",
	socialLinkedin: "LinkedIn ↗",
	socialGithub: "GitHub ↗",
};
---

<Layout title="Yanis Amani // Étudiant en Informatique" lang={lang}>
	<section class="hero" data-animate>
		<div class="container hero-inner">
			<span class="hero-tag">{t.heroTag}</span>
			<div class="accent-rule"></div>
			<h1 class="hero-title">
				{t.heroName}<br/>
				<span class="hero-accent">{t.heroNameAccent}</span>
			</h1>
			<p class="hero-role">{t.heroRole}</p>
			<div class="hero-actions">
				<a href="#projects" class="btn-primary">{t.ctaProjects}</a>
				<a href="#contact" class="btn-ghost">{t.ctaContact}</a>
			</div>
		</div>
	</section>

	<div class="container">
		<div class="info-bar">
			<div class="info-item" style="background: var(--bg);">
				<div class="label">{t.infoRole}</div>
				<div class="value">{t.infoRoleVal}</div>
			</div>
			<div class="info-item" style="background: var(--bg);">
				<div class="label">{t.infoFocus}</div>
				<div class="value">{t.infoFocusVal}</div>
			</div>
			<div class="info-item" style="background: var(--bg);">
				<div class="label">{t.infoEdu}</div>
				<div class="value">{t.infoEduVal}</div>
			</div>
		</div>
	</div>

	<section id="projects" class="section-pad">
		<div class="container">
			<div class="section-header" data-animate>
				<h2>{t.projectsTitle}</h2>
				<p class="sub">{t.projectsSub}</p>
			</div>

			<div class="projects-list">
				{projects.map((p) => (
					<article class="project-card" data-animate>
						<div class="project-top">
							<span class="cat">{p.category[lang]}</span>
							<span class="project-detail-link">Voir plus</span>
						</div>
						<h3 class="name">{p.name}</h3>
						<p class="desc">{p.description[lang]}</p>
						<div class="project-meta">
							{p.tags.map((tag) => (
								<a href={tag.url} target="_blank" rel="noopener noreferrer" class="tech-tag">{tag.name}</a>
							))}
							{p.link.url ? (
								<a href={p.link.url} target="_blank" rel="noopener noreferrer" class="project-link">
									{p.link.label}
								</a>
							) : (
								<span class="project-link" style="opacity: 0.4; cursor: default;">{p.link.label}</span>
							)}
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="container" style="padding-bottom: 4rem;">
		<div class="static-header">
			<span class="static-label">{t.staticTitle}</span>
			<span class="static-count">{staticSites.length} projets</span>
		</div>
		<div class="static-grid">
			{staticSites.map((site, i) => (
				<a href={site.url} target="_blank" rel="noopener noreferrer" class="static-card">
					<div class="num">0{i + 1}</div>
					<h3 class="name">{site.name}</h3>
					<p class="desc">{site.description[lang]}</p>
					<div class="static-tags">
						{site.tags.map((tag) => (
							<span class="mini-tag">{tag}</span>
						))}
					</div>
					<span class="static-hover-text">cliquer pour accéder</span>
				</a>
			))}
		</div>
	</section>

	<section id="skills" class="section-pad" style="border-top: 1px solid var(--border);">
		<div class="container">
			<div class="section-header" data-animate>
				<h2>{t.skillsTitle}</h2>
				<p class="sub">{t.skillsSub}</p>
			</div>

			<div class="skills-filter" data-animate>
				<button class="skills-filter-btn active" data-filter="all">Tous</button>
				<button class="skills-filter-btn" data-filter="lang">Langages</button>
				<button class="skills-filter-btn" data-filter="frontend">Frontend</button>
				<button class="skills-filter-btn" data-filter="backend">Backend</button>
				<button class="skills-filter-btn" data-filter="systems">Système</button>
			</div>

			<div class="skills-grid" data-animate>
				{skills.map((s) => (
					<div class="skill-item" data-category={s.category}>
						<span class="s-cat">{s.category}</span>
						<div class="s-name">{s.name}</div>
						<div class="s-bar">
							<div class="s-bar-fill" style={`width: ${s.level[lang] === 'Advanced' || s.level[lang] === 'Avancé' ? '100%' : s.level[lang] === 'Proficient' || s.level[lang] === 'Compétent' ? '70%' : '40%'}`}></div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="about" class="section-pad" style="border-top: 1px solid var(--border);">
		<div class="container">
			<div class="section-header" data-animate>
				<h2>{t.aboutTitle}</h2>
				<p class="sub">{t.aboutSub}</p>
			</div>

			<div class="about-grid" data-animate>
				<p class="about-text">{t.aboutText}</p>
				<div class="values-box">
					<div class="v-label">{t.valuesTitle}</div>
					{t.values.map((v) => (
						<div class="v-item">{v}</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="contact" class="section-pad" style="border-top: 1px solid var(--border); margin-bottom: 4rem;">
		<div class="container">
			<div class="section-header" data-animate>
				<h2>{t.contactTitle}</h2>
				<p class="sub">{t.contactSub}</p>
			</div>

			<div class="contact-grid" data-animate>
				<div>
					<p class="contact-label">Email</p>
					<a href="mailto:yanis.amani@icloud.com" class="contact-email">
						yanis.amani@icloud.com
					</a>
					<p class="contact-label" style="margin-top: 2rem;">Social</p>
					<div class="contact-socials">
						<a href="https://linkedin.com/in/yanis-amani" target="_blank" class="social-link">{t.socialLinkedin}</a>
						<a href="https://github.com/DevYatsu" target="_blank" class="social-link">{t.socialGithub}</a>
					</div>
				</div>
				<div class="contact-hello">
					<p class="contact-label">Dire bonjour</p>
					<a href="mailto:yanis.amani@icloud.com" class="big-hello">bonjour@ →</a>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	document.addEventListener('astro:page-load', () => {
		const buttons = document.querySelectorAll('.skills-filter-btn');
		const items = document.querySelectorAll('.skill-item');
		buttons.forEach(btn => {
			btn.addEventListener('click', () => {
				const filter = btn.dataset.filter;
				buttons.forEach(b => b.classList.remove('active'));
				btn.classList.add('active');
				items.forEach(item => {
					item.style.display = (filter === 'all' || item.dataset.category === filter) ? 'block' : 'none';
				});
			});
		});
	});
</script>

<style>
	.hero {
		min-height: 85vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding-top: 3.5rem;
	}
	.hero-tag {
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--accent);
		font-weight: 500;
		margin-bottom: 1.25rem;
		display: block;
	}
	.hero .accent-rule { margin-bottom: 2rem; }
	.hero-title {
		font-size: clamp(2.5rem, 8vw, 5rem);
		letter-spacing: -0.03em;
		line-height: 0.92;
		margin-bottom: 1.5rem;
	}
	.hero-accent { font-style: italic; color: var(--accent); }
	.hero-role {
		font-size: 1rem;
		color: var(--text-muted);
		line-height: 1.6;
		max-width: 32rem;
		margin-bottom: 2.5rem;
	}
	@media (min-width: 768px) { .hero-role { font-size: 1.125rem; } }
	.hero-actions { display: flex; gap: 1rem; align-items: center; }

	.info-bar {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: var(--border);
		border-top: 1px solid var(--border);
	}

	.projects-list { display: flex; flex-direction: column; gap: 1.5rem; }
	.project-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem; }
	.project-detail-link { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text); opacity: 0.35; font-weight: 400; transition: opacity 0.2s; }
	.project-card:hover .project-detail-link { opacity: 0.6; }
	.project-meta { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
	.project-link {
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--accent);
		font-weight: 500;
		text-decoration: none;
		margin-left: auto;
		transition: color 0.2s;
		white-space: nowrap;
	}
	.project-link:hover { color: var(--accent-hover); }


	.static-header {
		border-top: 1px solid var(--border);
		padding-top: 2.5rem;
		margin-bottom: 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.static-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--text-dim); }
	.static-count { font-size: 0.65rem; color: var(--text-dim); }
	.static-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1px;
		background: var(--border);
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
	}
	@media (min-width: 640px) { .static-grid { grid-template-columns: repeat(2, 1fr); } }
	@media (min-width: 1024px) { .static-grid { grid-template-columns: repeat(3, 1fr); } }
	.static-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }

	.skills-filter { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
	.skills-filter-btn { font-family: var(--font-sans); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.12em; padding: 0.4rem 0.85rem; border: 1px solid var(--border); border-radius: 999px; background: transparent; color: var(--text-muted); cursor: pointer; transition: all 0.2s; }
	.skills-filter-btn:hover { border-color: var(--accent); color: var(--accent); }
	.skills-filter-btn.active { background: var(--accent); color: white; border-color: var(--accent); }

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1px;
		background: var(--border);
		border: 1px solid var(--border);
	}
	@media (min-width: 768px) { .skills-grid { grid-template-columns: repeat(3, 1fr); } }
	@media (min-width: 1024px) { .skills-grid { grid-template-columns: repeat(4, 1fr); } }

	.about-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		align-items: start;
	}
	@media (min-width: 1024px) { .about-grid { grid-template-columns: 2fr 1fr; } }
	.about-text { font-size: 1.125rem; color: var(--text-muted); line-height: 1.7; }

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: center;
	}
	@media (min-width: 768px) { .contact-grid { grid-template-columns: 1fr 1fr; } }
	.contact-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--text-dim); margin-bottom: 0.5rem; }
	.contact-socials { display: flex; gap: 1.5rem; }
	.contact-hello { text-align: right; }
	@media (max-width: 767px) { .contact-hello { text-align: left; } }
</style>
