---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects, skills } from "../data/portfolio";

const lang = "fr" as "en" | "fr";
const isFr = lang === "fr";

const content = {
	title: "Yanis Amani // Étudiant en Informatique",
	description:
		"Étudiant en Informatique. Je me concentre sur la création de solutions logicielles fiables, rapides et de haute qualité.",
	heroTitle: "CONSTRUIRE LA",
	heroTitle2: "FIABILITÉ",
	heroSubtitle: "Étudiant en Informatique",
	heroPara:
		"Je suis un étudiant en informatique créant des logiciels rapides, sécurisés et conçus pour durer. Je privilégie la qualité et la stabilité dans chaque projet.",
	projectsTitle: "PROJETS SÉLECTIONNÉS",
	skillsTitle: "MES OUTILS",
	perspectiveTitle: "MON APPROCHE",
	perspectivePara:
		"Je crois qu'un bon logiciel doit être invisible : il doit simplement fonctionner. Je me concentre sur les détails qui rendent les applications fiables et faciles à maintenir, pour que chaque projet soit solide dès sa conception.",
	contactTitle: "ME CONTACTER",
	contactPara:
		"Je suis toujours ouvert à discuter de nouveaux projets, de développement logiciel de qualité ou d'opportunités de stage.",
};
---

<Layout title={content.title} description={content.description} lang={lang}>
  <!-- Hero Section -->
  <section id="hero" class="min-h-[90vh] flex flex-col justify-center relative px-6 md:px-12 max-w-7xl mx-auto py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
      <div class="lg:col-span-8" data-animate>
        <div class="flex items-center gap-4 mb-8">
          <span class="tech-label">PORTFOLIO</span>
          <div class="h-px w-12 bg-primary/30"></div>
          <span class="font-mono text-[0.6rem] text-text-dim uppercase tracking-widest">NEUCHÂTEL, SUISSE</span>
        </div>
        
        <h1 class="display-title mb-8">
          {content.heroTitle}<br/>
          <span class="text-primary">{content.heroTitle2}</span>
        </h1>

        <p class="text-xl md:text-2xl font-medium text-text-muted max-w-2xl leading-tight">
          {content.heroPara}
        </p>
      </div>

      <div class="lg:col-span-4" data-animate data-delay="1">
        <div class="structural-border p-8 bg-bg-surface/50 backdrop-blur-sm space-y-6">
          <div class="flex justify-between items-start">
            <span class="tech-label">INFOS CLÉS</span>
            <div class="w-2 h-2 bg-primary animate-pulse"></div>
          </div>
          <ul class="font-mono text-[0.7rem] space-y-4 text-text-muted">
            <li class="flex justify-between border-b border-border-subtle pb-2">
              <span>RÔLE</span>
              <span class="text-text-main font-bold">ÉTUDIANT</span>
            </li>
            <li class="flex justify-between border-b border-border-subtle pb-2">
              <span>FOCUS</span>
              <span class="text-text-main font-bold">CODE QUALITÉ</span>
            </li>
            <li class="flex justify-between border-b border-border-subtle pb-2">
              <span>FORMATION</span>
              <span class="text-text-main font-bold">BSc INFORMATIQUE</span>
            </li>
            <li class="flex justify-between">
              <span>STATUT</span>
              <span class="text-primary font-bold">DISPONIBLE 2026</span>
            </li>
          </ul>
          <a href="#projects" class="btn-arch w-full justify-center mt-4 uppercase">
            Voir mes projets
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-32 px-6 md:px-12 max-w-7xl mx-auto border-t border-border-subtle">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-20" data-animate>
      <div>
        <span class="tech-label mb-6 inline-block">SECTION 01</span>
        <h2 class="display-md uppercase font-black">{content.projectsTitle}</h2>
      </div>
      <p class="text-text-muted font-mono text-[0.7rem] uppercase tracking-widest md:text-right max-w-xs">
        Une sélection de projets récents axés sur la stabilité et le design épuré.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-1">
      {projects.map((p, i) => (
        <div data-animate data-delay={String((i % 3) + 1)}>
          <ProjectCard project={p} lang={lang} />
        </div>
      ))}
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="py-32 px-6 md:px-12 max-w-7xl mx-auto border-t border-border-subtle bg-bg-accent/30">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
      <div class="lg:col-span-4" data-animate>
        <span class="tech-label mb-6 inline-block">SECTION 02</span>
        <h2 class="display-md uppercase font-black mb-8">{content.skillsTitle}</h2>
        <p class="text-text-muted leading-relaxed">
          J'utilise des outils modernes pour construire des logiciels fiables. Je privilégie les technologies qui assurent une sécurité et une stabilité à long terme.
        </p>
      </div>

      <div class="lg:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-px bg-border-subtle border border-border-subtle">
        {skills.map((s, i) => (
          <div class="bg-bg-base p-8 hover:bg-primary/5 transition-colors group" data-animate data-delay={String((i % 4) + 1)}>
            <div class="flex justify-between items-center mb-6">
              <span class="font-mono text-[0.6rem] text-text-dim">0{i + 1}</span>
              <span class="tech-label group-hover:bg-primary group-hover:text-white transition-colors">{s.level[lang]}</span>
            </div>
            <h3 class="text-xl font-black uppercase mb-4">{s.name}</h3>
            <div class="h-1 bg-border-subtle w-full relative overflow-hidden">
              <div 
                class="absolute inset-y-0 left-0 bg-primary transition-all duration-1000 ease-out delay-300"
                style={`width: ${s.level[lang] === 'Advanced' || s.level[lang] === 'Avancé' ? '100%' : (s.level[lang] === 'Proficient' || s.level[lang] === 'Compétent') ? '70%' : '40%'}`}
              ></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-32 px-6 md:px-12 max-w-7xl mx-auto border-t border-border-subtle">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-24 items-center">
      <div class="lg:col-span-7" data-animate>
        <span class="tech-label mb-6 inline-block">SECTION 03</span>
        <h2 class="display-md uppercase font-black mb-10 leading-[0.85]">
          {content.perspectiveTitle}
        </h2>
        <div class="space-y-6 text-xl text-text-muted leading-relaxed">
          <p>{content.perspectivePara}</p>
          <p class="text-primary font-black uppercase italic">
            La qualité n'est pas une option.
          </p>
        </div>
      </div>
      
      <div class="lg:col-span-5 grid grid-cols-2 gap-4" data-animate data-delay="1">
        <div class="structural-border p-6 bg-bg-surface">
          <span class="tech-label block mb-4 text-primary">01</span>
          <span class="font-black text-2xl uppercase">Fiable</span>
        </div>
        <div class="structural-border p-6 bg-primary text-white">
          <span class="tech-label block mb-4 border-white/30 text-white bg-white/10">02</span>
          <span class="font-black text-2xl uppercase">Sécurisé</span>
        </div>
        <div class="structural-border p-6 bg-bg-surface">
          <span class="tech-label block mb-4 text-primary">03</span>
          <span class="font-black text-2xl uppercase">Rapide</span>
        </div>
        <div class="structural-border p-6 bg-bg-surface">
          <span class="tech-label block mb-4 text-primary">04</span>
          <span class="font-black text-xl uppercase leading-none">HE-ARC</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-32 px-6 md:px-12 max-w-7xl mx-auto border-t border-border-subtle mb-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-24 items-start">
      <div class="lg:col-span-5" data-animate>
        <span class="tech-label mb-6 inline-block">SECTION 04</span>
        <h2 class="display-md uppercase font-black mb-8">{content.contactTitle}</h2>
        <p class="text-text-muted text-lg leading-relaxed mb-12">
          {content.contactPara}
        </p>
        
        <div class="space-y-4">
          <a href="mailto:yanis.amani@icloud.com" class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-black text-primary hover:text-primary-dark transition-colors block tracking-tighter">
            <span class="block text-text-main">YANIS.AMANI</span>
            <span class="block">@ICLOUD.COM</span>
          </a>
          <div class="flex gap-8 mt-12">
            <a href="https://linkedin.com/in/yanis-amani" target="_blank" class="nav-link">LINKEDIN ↗</a>
            <a href="https://github.com/DevYatsu" target="_blank" class="nav-link">GITHUB ↗</a>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7" data-animate data-delay="1">
        <div class="structural-border p-1 md:p-12 bg-bg-surface/50 backdrop-blur-sm">
          <form id="contact-form" action="https://formspree.io/f/mdabyqvb" method="POST" class="space-y-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
              <div class="space-y-4">
                <label class="tech-label">VOTRE NOM</label>
                <input type="text" name="name" required placeholder="NOM" class="w-full bg-transparent border-b border-border-subtle py-4 font-mono text-sm focus:outline-none focus:border-primary transition-colors" />
              </div>
              <div class="space-y-4">
                <label class="tech-label">VOTRE EMAIL</label>
                <input type="email" name="email" required placeholder="EMAIL" class="w-full bg-transparent border-b border-border-subtle py-4 font-mono text-sm focus:outline-none focus:border-primary transition-colors" />
              </div>
            </div>
            <div class="space-y-4">
              <label class="tech-label">VOTRE MESSAGE</label>
              <textarea name="message" required rows="4" placeholder="COMMENT PUIS-JE VOUS AIDER ?" class="w-full bg-transparent border-b border-border-subtle py-4 font-mono text-sm focus:outline-none focus:border-primary transition-colors resize-none"></textarea>
            </div>
            <button type="submit" class="btn-arch w-full py-6 text-lg uppercase tracking-widest">
              ENVOYER LE MESSAGE
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (submitBtn) submitBtn.disabled = true;

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          window.location.href = '/merci';
        } else {
          const data = await response.json();
          alert(data.error || "Une erreur est survenue. Veuillez réessayer.");
          if (submitBtn) submitBtn.disabled = false;
        }
      } catch (error) {
        alert("Erreur de connexion. Veuillez réessayer plus tard.");
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>
